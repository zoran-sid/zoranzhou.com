---
// Root language selection page – Apple-style splash
// Redirects immediately if user already has a language preference
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ZORAN ZHOU</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans SC", sans-serif;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f5f5f7;
      color: #1d1d1f;
    }
    .container {
      text-align: center;
      padding: 2rem;
      max-width: 600px;
    }
    .brand {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.25rem;
    }
    .tagline {
      font-size: 0.875rem;
      color: #6e6e73;
      margin-bottom: 3rem;
    }
    .heading {
      font-size: 1.5rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 2rem;
    }
    .options {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .lang-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 160px;
      height: 140px;
      border-radius: 16px;
      background: #fff;
      border: 2px solid transparent;
      cursor: pointer;
      transition: all 0.25s ease;
      text-decoration: none;
      color: #1d1d1f;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .lang-card:hover {
      border-color: #0071e3;
      box-shadow: 0 4px 20px rgba(0,113,227,0.15);
      transform: translateY(-2px);
    }
    .lang-card:active { transform: scale(0.97); }
    .lang-icon {
      font-size: 2rem;
      line-height: 1;
    }
    .lang-name {
      font-size: 1.125rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }
    .lang-sub {
      font-size: 0.8125rem;
      color: #6e6e73;
    }
    .footer-note {
      margin-top: 2.5rem;
      font-size: 0.8125rem;
      color: #aeaeb2;
    }
    @media (prefers-color-scheme: dark) {
      body { background: #000; color: #f5f5f7; }
      .lang-card { background: #1c1c1e; color: #f5f5f7; box-shadow: 0 2px 8px rgba(0,0,0,0.3); }
      .lang-card:hover { border-color: #2997ff; box-shadow: 0 4px 20px rgba(41,151,255,0.2); }
      .tagline, .lang-sub { color: #86868b; }
      .footer-note { color: #6e6e73; }
    }

    /* Fade-in animation */
    .animate-in {
      opacity: 0;
      transform: translateY(12px);
      animation: fadeUp 0.6s ease forwards;
    }
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
  <script>
    // If user already chose a language, redirect immediately (no flash)
    (function() {
      var pref = localStorage.getItem("pref-lang");
      if (!pref) {
        pref = document.cookie.match(/(?:^|;\s*)pref-lang=([^;]*)/);
        pref = pref ? decodeURIComponent(pref[1]) : null;
      }
      if (pref === "zh-CN" || pref === "en") {
        var target = "/" + pref + "/";
        // Preserve any original path the user might have wanted
        window.location.replace(target);
      }
    })();
  </script>
</head>
<body>
  <div class="container">
    <div class="brand animate-in">ZORAN ZHOU</div>
    <p class="tagline animate-in delay-1">Security Researcher & Developer</p>

    <h1 class="heading animate-in delay-2">Choose your language<br>选择语言</h1>

    <div class="options animate-in delay-3">
      <button class="lang-card" data-lang="zh-CN" aria-label="中文">
        <span class="lang-icon">🇨🇳</span>
        <span class="lang-name">中文</span>
        <span class="lang-sub">简体中文</span>
      </button>
      <button class="lang-card" data-lang="en" aria-label="English">
        <span class="lang-icon">🌐</span>
        <span class="lang-name">English</span>
        <span class="lang-sub">English</span>
      </button>
    </div>

    <p class="footer-note animate-in delay-3">You can change this anytime in the navigation bar.</p>
  </div>

  <script>
    var cards = document.querySelectorAll(".lang-card");
    cards.forEach(function(card) {
      card.addEventListener("click", function() {
        var lang = this.getAttribute("data-lang");
        // Persist preference
        localStorage.setItem("pref-lang", lang);
        document.cookie = "pref-lang=" + lang + ";path=/;max-age=31536000;SameSite=Lax";
        // Navigate to chosen locale
        window.location.href = "/" + lang + "/";
      });
    });
  </script>
</body>
</html>

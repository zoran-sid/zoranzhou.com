---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { getLocalPhotoAlbums } from "../../../lib/photos";
import { getTranslations, type Locale, locales } from "../../../i18n/utils";

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

const photoEntries = await getCollection(
  "photos",
  ({ data }) => !data.draft && data.lang === locale,
);

const markdownAlbums = photoEntries
  .map((entry) => ({
    slug: entry.id.replace(/\.md$/, "").replace(/\.(zh-CN|en)$/i, ""),
    title: entry.data.title,
    description: entry.data.description,
    date: entry.data.date.toISOString().slice(0, 10),
    location: entry.data.location,
    camera: entry.data.camera,
    photos: entry.data.gallery.map((photo, index) => ({
      id: `${entry.id}-${index}`,
      src: photo.src,
      alt: photo.alt || entry.data.title,
      caption: photo.caption,
      image: null,
    })),
  }))
  .filter((album) => album.photos.length > 0);

const localAlbums = getLocalPhotoAlbums().map((album) => ({
  slug: album.slug,
  title: album.title,
  description: undefined,
  date: album.date ?? "",
  location: undefined,
  camera: undefined,
  photos: album.photos.map((photo) => ({
    id: photo.id,
    src: photo.image.src,
    alt: photo.alt,
    caption: undefined,
    image: photo.image,
  })),
}));

const albums = [...markdownAlbums, ...localAlbums].sort((a, b) =>
  b.date.localeCompare(a.date),
);

const photos = albums.flatMap((album) =>
  album.photos.map((photo) => ({
    ...photo,
    albumTitle: album.title,
    albumDescription: album.description,
    date: album.date,
    location: album.location,
    camera: album.camera,
  })),
);

const copy =
  locale === "zh-CN"
    ? {
        library: "照片资料库",
        close: "关闭",
        previous: "上一张",
        next: "下一张",
      }
    : {
        library: "Photo library",
        close: "Close",
        previous: "Previous",
        next: "Next",
      };
---

<BaseLayout title={t.photosPageTitle} description={t.photosPageDescription}>
  <main class="photo-page">
    <header class="photo-page__header">
      <div>
        <p class="section-kicker">{copy.library}</p>
        <h1 class="photo-page__title">{t.photosPageTitle}</h1>
        <p class="photo-page__description">{t.photosPageDescription}</p>
      </div>
    </header>

    {
      photos.length === 0 ? (
        <p class="photo-empty">{t.photosEmpty}</p>
      ) : (
        <div class="photo-grid" aria-label={copy.library}>
          {photos.map((photo, index) => (
            <button
              type="button"
              class="photo-tile"
              data-photo-button
              data-index={String(index)}
              data-src={photo.src}
              data-alt={photo.alt}
              data-title={photo.albumTitle}
              data-caption={photo.caption || photo.albumDescription || ""}
              data-date={photo.date}
              data-location={photo.location || ""}
              data-camera={photo.camera || ""}
              aria-label={`${photo.albumTitle}: ${photo.alt}`}
            >
              {photo.image ? (
                <Image
                  src={photo.image}
                  alt={photo.alt}
                  widths={[240, 400, 640]}
                  sizes="(max-width: 640px) 33vw, (max-width: 1100px) 20vw, 16vw"
                  loading={index < 6 ? "eager" : "lazy"}
                  decoding="async"
                />
              ) : (
                <img
                  src={photo.src}
                  alt={photo.alt}
                  loading={index < 6 ? "eager" : "lazy"}
                  decoding="async"
                  fetchpriority={index === 0 ? "high" : "auto"}
                />
              )}
              <span class="photo-tile__shade" aria-hidden="true">
                <strong>{photo.albumTitle}</strong>
                {photo.date && <time datetime={photo.date}>{photo.date}</time>}
              </span>
            </button>
          ))}
        </div>
      )
    }

    <dialog
      class="photo-lightbox"
      data-photo-lightbox
      aria-label={t.photosPageTitle}
    >
      <div class="photo-lightbox__topbar">
        <span data-lightbox-count></span>
        <button
          type="button"
          class="photo-lightbox__close"
          data-lightbox-close
          aria-label={copy.close}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true"
            ><path d="M6 6l12 12M18 6 6 18"></path></svg
          >
        </button>
      </div>
      <button
        type="button"
        class="photo-lightbox__nav photo-lightbox__prev"
        data-lightbox-prev
        aria-label={copy.previous}>&lsaquo;</button
      >
      <figure class="photo-lightbox__figure">
        <img data-lightbox-image src="" alt="" />
        <figcaption class="photo-lightbox__caption">
          <div>
            <strong data-lightbox-title></strong>
            <p data-lightbox-caption></p>
          </div>
          <div class="photo-lightbox__meta" data-lightbox-meta></div>
        </figcaption>
      </figure>
      <button
        type="button"
        class="photo-lightbox__nav photo-lightbox__next"
        data-lightbox-next
        aria-label={copy.next}>&rsaquo;</button
      >
    </dialog>
  </main>
</BaseLayout>

<script>
  const buttons = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-photo-button]"),
  );
  const dialog = document.querySelector<HTMLDialogElement>(
    "[data-photo-lightbox]",
  );
  const image = dialog?.querySelector<HTMLImageElement>(
    "[data-lightbox-image]",
  );
  const count = dialog?.querySelector<HTMLElement>("[data-lightbox-count]");
  const title = dialog?.querySelector<HTMLElement>("[data-lightbox-title]");
  const caption = dialog?.querySelector<HTMLElement>("[data-lightbox-caption]");
  const meta = dialog?.querySelector<HTMLElement>("[data-lightbox-meta]");
  const closeBtn = dialog?.querySelector<HTMLButtonElement>(
    "[data-lightbox-close]",
  );
  const prevBtn = dialog?.querySelector<HTMLButtonElement>(
    "[data-lightbox-prev]",
  );
  const nextBtn = dialog?.querySelector<HTMLButtonElement>(
    "[data-lightbox-next]",
  );
  let activeIndex = 0;
  let touchStartX = 0;

  function showPhoto(index: number) {
    if (!dialog || !image || buttons.length === 0) return;
    activeIndex = (index + buttons.length) % buttons.length;
    const item = buttons[activeIndex];
    image.src = item.dataset.src ?? "";
    image.alt = item.dataset.alt ?? "";
    if (count) count.textContent = `${activeIndex + 1} / ${buttons.length}`;
    if (title) title.textContent = item.dataset.title ?? "";
    if (caption) {
      caption.textContent = item.dataset.caption ?? "";
      caption.hidden = !caption.textContent;
    }
    if (meta) {
      meta.textContent = [
        item.dataset.date,
        item.dataset.location,
        item.dataset.camera,
      ]
        .filter(Boolean)
        .join(" · ");
    }
    if (!dialog.open) {
      dialog.showModal();
      document.documentElement.classList.add("photo-lightbox-open");
    }
  }

  function closeLightbox() {
    dialog?.close();
  }

  buttons.forEach((button, index) =>
    button.addEventListener("click", () => showPhoto(index)),
  );
  closeBtn?.addEventListener("click", closeLightbox);
  prevBtn?.addEventListener("click", () => showPhoto(activeIndex - 1));
  nextBtn?.addEventListener("click", () => showPhoto(activeIndex + 1));
  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) closeLightbox();
  });
  dialog?.addEventListener("close", () => {
    document.documentElement.classList.remove("photo-lightbox-open");
  });
  dialog?.addEventListener(
    "touchstart",
    (event) => {
      touchStartX = event.changedTouches[0]?.clientX ?? 0;
    },
    { passive: true },
  );
  dialog?.addEventListener(
    "touchend",
    (event) => {
      const distance = (event.changedTouches[0]?.clientX ?? 0) - touchStartX;
      if (Math.abs(distance) < 50) return;
      showPhoto(activeIndex + (distance < 0 ? 1 : -1));
    },
    { passive: true },
  );
  document.addEventListener("keydown", (event) => {
    if (!dialog?.open) return;
    if (event.key === "ArrowLeft") showPhoto(activeIndex - 1);
    if (event.key === "ArrowRight") showPhoto(activeIndex + 1);
  });
</script>

<style>
  .photo-page {
    width: min(100%, 1920px);
    margin-inline: auto;
    padding: clamp(1rem, 3vw, 3.5rem);
  }
  .photo-page__header {
    position: relative;
    padding: clamp(2.5rem, 7vw, 6.5rem) clamp(0.25rem, 2vw, 2rem)
      clamp(2rem, 5vw, 4.5rem);
    border-bottom: 1px solid rgb(var(--accent-rgb) / 0.15);
  }
  .photo-page__header::before {
    position: absolute;
    top: 1.5rem;
    right: clamp(0.25rem, 2vw, 2rem);
    color: var(--faint);
    content: "VISUAL ARCHIVE / GRID MODE";
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.14em;
  }
  .photo-page__title {
    margin: 0.7rem 0 0;
    padding-right: 0.08em;
    padding-bottom: 0.05em;
    background: linear-gradient(
      105deg,
      var(--ink),
      var(--accent) 72%,
      var(--signal)
    );
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    font-size: clamp(3.2rem, 9vw, 8.8rem);
    font-weight: 650;
    letter-spacing: -0.075em;
    line-height: 0.85;
  }
  .photo-page__description {
    max-width: 42rem;
    margin: 1.5rem 0 0;
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
  }
  .photo-grid {
    display: grid;
    padding-top: clamp(1.5rem, 3vw, 2.5rem);
    overflow: visible;
    border-radius: 0;
    background: transparent;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 3px;
  }
  .photo-tile {
    position: relative;
    display: block;
    aspect-ratio: 1;
    min-width: 0;
    padding: 0;
    overflow: hidden;
    border: 1px solid rgb(var(--accent-rgb) / 0.1);
    border-radius: 0.28rem;
    background: var(--surface-soft);
    cursor: zoom-in;
  }
  .photo-tile img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.002);
    transition:
      transform 500ms var(--ease-out),
      filter 300ms ease;
  }
  .photo-tile__shade {
    position: absolute;
    inset: auto 0 0;
    display: grid;
    gap: 0.15rem;
    padding: 2.5rem 0.8rem 0.7rem;
    background: linear-gradient(transparent, rgb(2 6 18 / 0.72));
    color: white;
    opacity: 0;
    transform: translateY(0.5rem);
    transition:
      opacity 220ms ease,
      transform 350ms var(--ease-out);
  }
  .photo-tile__shade strong {
    overflow: hidden;
    font-size: 0.72rem;
    font-weight: 600;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .photo-tile__shade time {
    color: rgb(255 255 255 / 0.66);
    font-family: var(--font-mono);
    font-size: 0.55rem;
  }
  .photo-tile:hover img {
    filter: saturate(1.08) contrast(1.03);
    transform: scale(1.055);
  }
  .photo-tile:hover {
    z-index: 2;
    border-color: rgb(var(--accent-rgb) / 0.45);
    box-shadow: 0 14px 38px rgb(var(--accent-rgb) / 0.16);
  }
  .photo-tile:hover .photo-tile__shade,
  .photo-tile:focus-visible .photo-tile__shade {
    opacity: 1;
    transform: translateY(0);
  }
  .photo-tile:focus-visible {
    z-index: 2;
    outline: 3px solid var(--signal);
    outline-offset: -3px;
  }
  .photo-lightbox {
    width: 100vw;
    max-width: none;
    height: 100dvh;
    max-height: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
    border: 0;
    background: rgb(4 7 13 / 0.97);
    color: white;
  }
  .photo-lightbox::backdrop {
    background: rgb(2 4 8 / 0.9);
    backdrop-filter: blur(12px);
  }
  .photo-lightbox[open] {
    display: grid;
    grid-template-columns: clamp(3.25rem, 6vw, 5.5rem) minmax(0, 1fr) clamp(
        3.25rem,
        6vw,
        5.5rem
      );
    align-items: center;
  }
  .photo-lightbox__topbar {
    position: absolute;
    z-index: 3;
    top: 0;
    right: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: max(0.8rem, env(safe-area-inset-top))
      max(0.8rem, env(safe-area-inset-right)) 0.8rem
      max(0.8rem, env(safe-area-inset-left));
    background: linear-gradient(rgb(2 4 9 / 0.72), transparent);
    color: rgb(255 255 255 / 0.68);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  .photo-lightbox__close,
  .photo-lightbox__nav {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    place-items: center;
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: 50%;
    background: rgb(255 255 255 / 0.08);
    color: #fff;
    cursor: pointer;
    backdrop-filter: blur(12px);
    transition:
      background 160ms ease,
      transform 250ms var(--ease-out);
  }
  .photo-lightbox__close:hover,
  .photo-lightbox__nav:hover {
    background: rgb(255 255 255 / 0.17);
    transform: scale(1.05);
  }
  .photo-lightbox__close svg {
    width: 1.15rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 1.8;
  }
  .photo-lightbox__nav {
    z-index: 2;
    justify-self: center;
    font-size: 2rem;
    line-height: 1;
  }
  .photo-lightbox__figure {
    display: grid;
    width: 100%;
    height: 100dvh;
    min-width: 0;
    min-height: 0;
    margin: 0;
    padding: 4.5rem 1rem 1rem;
    grid-template-rows: minmax(0, 1fr) auto;
  }
  .photo-lightbox__figure > img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: contain;
  }
  .photo-lightbox__caption {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    min-height: 4rem;
    padding: 1rem 0.25rem 0.25rem;
    color: rgb(255 255 255 / 0.72);
  }
  .photo-lightbox__caption strong {
    color: white;
    font-size: 0.9rem;
  }
  .photo-lightbox__caption p {
    max-width: 40rem;
    margin: 0.2rem 0 0;
    color: rgb(255 255 255 / 0.58);
    font-size: 0.75rem;
    line-height: 1.45;
  }
  .photo-lightbox__meta {
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }
  .photo-empty {
    padding: 6rem 1.25rem;
    color: var(--faint);
    text-align: center;
  }
  @media (max-width: 1100px) {
    .photo-grid {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }
  }
  :global(html.photo-lightbox-open),
  :global(html.photo-lightbox-open body) {
    overflow: hidden;
    overscroll-behavior: none;
  }
  @media (max-width: 720px) {
    .photo-page {
      padding-inline: 3px;
    }
    .photo-page__header {
      padding-inline: 1.25rem;
    }
    .photo-page__header::before {
      right: 1.25rem;
    }
    .photo-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2px;
    }
    .photo-tile {
      border-radius: 0.16rem;
    }
    .photo-tile__shade {
      display: none;
    }
    .photo-lightbox[open] {
      display: block;
      width: 100vw;
      height: 100dvh;
    }
    .photo-lightbox__topbar {
      position: fixed;
      padding-top: max(0.8rem, env(safe-area-inset-top));
    }
    .photo-lightbox__nav {
      position: fixed;
      z-index: 4;
      top: 50%;
      width: 2.8rem;
      height: 2.8rem;
      transform: translateY(-50%);
    }
    .photo-lightbox__nav:hover {
      transform: translateY(-50%) scale(1.05);
    }
    .photo-lightbox__prev {
      left: max(0.55rem, env(safe-area-inset-left));
    }
    .photo-lightbox__next {
      right: max(0.55rem, env(safe-area-inset-right));
    }
    .photo-lightbox__figure {
      position: relative;
      display: flex;
      width: 100vw;
      height: 100dvh;
      padding: calc(4.1rem + env(safe-area-inset-top)) 0
        calc(4.6rem + env(safe-area-inset-bottom));
      align-items: center;
      justify-content: center;
    }
    .photo-lightbox__figure > img {
      width: 100%;
      height: 100%;
      max-width: 100vw;
      max-height: 100%;
      object-fit: contain;
      object-position: center;
    }
    .photo-lightbox__caption {
      position: fixed;
      right: max(1rem, env(safe-area-inset-right));
      bottom: max(0.9rem, env(safe-area-inset-bottom));
      left: max(1rem, env(safe-area-inset-left));
      display: block;
      min-height: 0;
      padding: 0;
      pointer-events: none;
    }
    .photo-lightbox__caption strong {
      display: block;
      max-width: calc(100vw - 2rem);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .photo-lightbox__caption p,
    .photo-lightbox__meta {
      display: none;
    }
  }
  @media (hover: none) {
    .photo-tile:hover img {
      filter: none;
      transform: scale(1.002);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .photo-tile img,
    .photo-tile__shade,
    .photo-lightbox__close,
    .photo-lightbox__nav {
      transition: none;
    }
  }
</style>

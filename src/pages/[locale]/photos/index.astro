---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getTranslations, localizePath, type Locale, locales } from "../../../i18n/utils";

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

const entries = (await getCollection("photos", ({ data }) => !data.draft))
  .filter((entry) => (entry.data.lang ?? "zh-CN") === locale)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={t.photosPageTitle} description={t.photosPageDescription}>
  <div class="page-container py-16 md:py-24">
    <header class="mb-12 max-w-3xl">
      <p class="text-sm font-medium uppercase text-gray-500 dark:text-gray-400">{t.navPhotos}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-100 md:text-5xl">
        {t.photosPageTitle}
      </h1>
      <p class="mt-4 text-lg leading-8 text-gray-500 dark:text-gray-400">{t.photosPageDescription}</p>
    </header>

    {entries.length === 0 ? (
      <p class="text-gray-400">{t.photosEmpty}</p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {entries.map((entry) => {
          const image = entry.data.cover?.src ?? entry.data.gallery[0]?.src;
          return (
            <a href={localizePath(`/photos/${entry.slug}`, locale)} class="group overflow-hidden rounded-lg border border-gray-200 bg-white no-underline transition-colors hover:border-gray-300 dark:border-gray-800 dark:bg-gray-950 dark:hover:border-gray-700">
              <div class="aspect-[4/3] bg-gray-100 dark:bg-gray-900">
                {image ? <img src={image} alt={entry.data.cover?.alt ?? entry.data.title} loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" /> : null}
              </div>
              <div class="p-4">
                <h2 class="text-lg font-semibold text-gray-900 transition-colors group-hover:text-blue-600 dark:text-gray-100">{entry.data.title}</h2>
                {entry.data.description && <p class="mt-2 line-clamp-2 text-sm leading-6 text-gray-500 dark:text-gray-400">{entry.data.description}</p>}
                <div class="mt-4 flex flex-wrap gap-2 text-xs text-gray-500 dark:text-gray-400">
                  {entry.data.location && <span>{t.photosLocation}: {entry.data.location}</span>}
                  {entry.data.camera && <span>{t.photosCamera}: {entry.data.camera}</span>}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>

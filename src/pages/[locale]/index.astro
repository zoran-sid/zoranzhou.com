---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import AboutSection from "../../components/AboutSection.astro";
import LatestArticles from "../../components/LatestArticles.astro";
import FeaturedResearch from "../../components/FeaturedResearch.astro";
import WorkingOn from "../../components/WorkingOn.astro";
import ProjectsGrid from "../../components/ProjectsGrid.astro";
import Skills from "../../components/Skills.astro";
import ContactSection from "../../components/ContactSection.astro";
import { locales, getTranslations, type Locale } from "../../i18n/utils";

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);
const siteUrl = new URL(Astro.site ?? "https://zoranzhou.com").href.replace(
  /\/$/,
  "",
);

const jsonld = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "ZORAN ZHOU",
  url: siteUrl,
  description: t.siteDescription,
  inLanguage: locale === "zh-CN" ? "zh-Hans" : "en",
  author: { "@type": "Person", name: "Zoran Zhou" },
};
---

<BaseLayout jsonld={jsonld}>
  <div class="home-experience" data-home-experience>
    <svg
      class="home-journey"
      viewBox="0 0 100 100"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id="journey-gradient" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="var(--signal)"></stop>
          <stop offset="0.48" stop-color="var(--accent)"></stop>
          <stop offset="1" stop-color="var(--accent-soft)"></stop>
        </linearGradient>
      </defs>
      <path
        class="home-journey__rail"
        d="M78 0 C82 7 84 10 67 15 S18 20 24 29 S82 34 73 42 S20 48 29 57 S85 62 70 71 S18 77 27 86 S76 91 63 100"
        pathLength="1"></path>
      <path
        class="home-journey__progress"
        d="M78 0 C82 7 84 10 67 15 S18 20 24 29 S82 34 73 42 S20 48 29 57 S85 62 70 71 S18 77 27 86 S76 91 63 100"
        pathLength="1"></path>
    </svg>
    <div class="home-journey__beacons" aria-hidden="true">
      <i class="beacon-a"></i>
      <i class="beacon-b"></i>
      <i class="beacon-c"></i>
      <i class="beacon-d"></i>
      <i class="beacon-e"></i>
      <i class="beacon-f"></i>
    </div>

    <HeroSection />
    <AboutSection />
    <LatestArticles />
    <FeaturedResearch />
    <WorkingOn />
    <ProjectsGrid />
    <Skills />
    <ContactSection />
  </div>
</BaseLayout>

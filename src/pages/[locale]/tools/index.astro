---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getTranslations, localizePath, type Locale, locales } from "../../../i18n/utils";

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);
const dateLocale = locale === "zh-CN" ? "zh-CN" : "en-US";

const tools = await getCollection("tools", ({ data }) => !data.draft);
const sorted = tools.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const categoryLabel: Record<string, string> = {
  cli: t.toolsCategoryCli,
  gui: t.toolsCategoryGui,
  saas: t.toolsCategorySaas,
  library: t.toolsCategoryLibrary,
  hardware: t.toolsCategoryHardware,
};

const pricingLabel: Record<string, string> = {
  free: t.toolsPricingFree,
  freemium: t.toolsPricingFreemium,
  paid: t.toolsPricingPaid,
  "open-source": t.toolsPricingOpenSource,
};
---

<BaseLayout
  title={t.toolsPageTitle}
  description={t.toolsPageDescription}
>
  <div class="page-container py-16 md:py-24">
    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 md:text-5xl">{t.toolsPageTitle}</h1>
      <p class="mt-3 text-lg text-gray-500">{t.toolsPageDescription}</p>
    </header>

    {
      sorted.length === 0 ? (
        <p class="text-gray-400">No tools yet.</p>
      ) : (
        <div class="divide-y divide-gray-100 dark:divide-gray-800">
          {sorted.map((tool) => (
            <a
              href={localizePath(`/tools/${tool.slug}`, locale)}
              class="group flex flex-col gap-3 py-6 no-underline transition-colors hover:bg-gray-50/50 -mx-4 px-4 rounded-lg sm:flex-row sm:items-baseline sm:gap-8"
            >
              <div class="flex shrink-0 items-center gap-3 sm:w-44 sm:flex-col sm:items-start sm:gap-1">
                <time datetime={tool.data.date.toISOString()} class="text-sm font-medium text-gray-900">
                  {tool.data.date.toLocaleDateString(dateLocale, { year: "numeric", month: "short", day: "numeric" })}
                </time>
                <div class="flex flex-wrap gap-1.5">
                  <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-500">
                    {categoryLabel[tool.data.category] ?? tool.data.category}
                  </span>
                  <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-500">
                    {pricingLabel[tool.data.pricing] ?? tool.data.pricing}
                  </span>
                </div>
              </div>
              <div class="min-w-0 flex-1">
                <h2 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">
                  {tool.data.title}
                </h2>
                {tool.data.description && (
                  <p class="mt-1 text-sm text-gray-500">{tool.data.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>

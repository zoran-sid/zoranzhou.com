---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getTranslations, localizePath, type Locale, locales } from "../../../i18n/utils";

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

const entries = (await getCollection("gear", ({ data }) => !data.draft))
  .filter((entry) => (entry.data.lang ?? "zh-CN") === locale)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryLabel: Record<string, string> = {
  computer: t.gearCategoryComputer,
  camera: t.gearCategoryCamera,
  phone: t.gearCategoryPhone,
  audio: t.gearCategoryAudio,
  network: t.gearCategoryNetwork,
  edc: t.gearCategoryEdc,
  sport: t.gearCategorySport,
  other: t.gearCategoryOther,
};

const statusLabel: Record<string, string> = {
  using: t.gearStatusUsing,
  testing: t.gearStatusTesting,
  retired: t.gearStatusRetired,
  wishlist: t.gearStatusWishlist,
};
---

<BaseLayout title={t.gearPageTitle} description={t.gearPageDescription}>
  <div class="page-container py-16 md:py-24">
    <header class="mb-12 max-w-3xl">
      <p class="text-sm font-medium uppercase text-gray-500 dark:text-gray-400">{t.navGear}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-100 md:text-5xl">
        {t.gearPageTitle}
      </h1>
      <p class="mt-4 text-lg leading-8 text-gray-500 dark:text-gray-400">{t.gearPageDescription}</p>
    </header>

    {entries.length === 0 ? (
      <p class="text-gray-400">{t.gearEmpty}</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {entries.map((entry) => (
          <a href={localizePath(`/gear/${entry.slug}`, locale)} class="group rounded-lg border border-gray-200 p-5 no-underline transition-colors hover:border-gray-300 hover:bg-gray-50/70 dark:border-gray-800 dark:hover:border-gray-700 dark:hover:bg-gray-900/50">
            <div class="flex items-start justify-between gap-4">
              <div>
                {entry.data.brand && <p class="text-xs font-medium uppercase text-gray-400">{entry.data.brand}</p>}
                <h2 class="mt-1 text-lg font-semibold text-gray-900 transition-colors group-hover:text-blue-600 dark:text-gray-100">{entry.data.title}</h2>
              </div>
              {entry.data.rating && <span class="text-sm text-yellow-600 dark:text-yellow-400">{"★".repeat(Math.round(entry.data.rating))}</span>}
            </div>
            {entry.data.description && <p class="mt-3 line-clamp-2 text-sm leading-6 text-gray-500 dark:text-gray-400">{entry.data.description}</p>}
            <div class="mt-5 flex flex-wrap gap-2 text-xs text-gray-500 dark:text-gray-400">
              <span class="rounded-md bg-gray-100 px-2 py-1 dark:bg-gray-800">{categoryLabel[entry.data.category]}</span>
              <span class="rounded-md bg-gray-100 px-2 py-1 dark:bg-gray-800">{statusLabel[entry.data.status]}</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

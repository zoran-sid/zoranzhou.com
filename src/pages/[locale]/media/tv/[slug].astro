---
import MediaLayout from "../../../../layouts/MediaLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const tv = await getCollection("tv", ({ data }) => !data.draft);
  return tv.map((entry) => ({
    params: { locale: entry.data.lang ?? "zh-CN", slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<MediaLayout entry={entry} />

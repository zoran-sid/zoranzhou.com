---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
  getTranslations,
  localizePath,
  type Locale,
  locales,
} from "../../../i18n/utils";

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

const allContent = [
  ...(await getCollection("blog", ({ data }) => !data.draft)),
  ...(await getCollection("essays", ({ data }) => !data.draft)),
  ...(await getCollection("research", ({ data }) => !data.draft)),
  ...(await getCollection("projects", ({ data }) => !data.draft)),
  ...(await getCollection("tools", ({ data }) => !data.draft)),
  ...(await getCollection("photos", ({ data }) => !data.draft)),
  ...(await getCollection("routes", ({ data }) => !data.draft && data.published !== false)),
];

const tagMap = new Map<string, number>();
for (const entry of allContent) {
  if ((entry.data.lang ?? "zh-CN") !== locale) continue;
  for (const tag of entry.data.tags) {
    const normalized = tag.toLowerCase().trim();
    tagMap.set(normalized, (tagMap.get(normalized) ?? 0) + 1);
  }
}

const sortedTags = [...tagMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([tag, count]) => ({ tag, count }));

const maxCount = sortedTags[0]?.count ?? 1;
---

<BaseLayout title={t.tagsTitle} description={t.tagsDescription}>
  <div class="page-container py-16 md:py-24">
    <header class="mb-12">
      <h1
        class="text-4xl font-bold tracking-tight text-gray-900 md:text-5xl dark:text-gray-100"
      >
        {t.tagsTitle}
      </h1>
      <p class="mt-3 text-lg text-gray-500 dark:text-gray-400">
        {t.tagsDescription}
      </p>
    </header>

    {
      sortedTags.length === 0 ? (
        <p class="text-gray-400 dark:text-gray-500">{t.tagsEmpty}</p>
      ) : (
        <div class="flex flex-wrap gap-3">
          {sortedTags.map(({ tag, count }) => (
            <a
              href={localizePath(`/tags/${tag.replace(/\s+/g, "-")}`, locale)}
              class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm text-gray-600 no-underline shadow-card transition-all duration-200 hover:border-blue-300 hover:text-blue-600 hover:shadow-card-hover dark:border-gray-700 dark:bg-gray-800/50 dark:text-gray-300 dark:hover:border-blue-600 dark:hover:text-blue-400"
            >
              {tag}
              <span class="ml-1.5 text-gray-400 dark:text-gray-500">
                ({count})
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
  getTranslations,
  localizePath,
  type Locale,
  locales,
} from "../../../i18n/utils";

export async function getStaticPaths() {
  const allContent = [
    ...(await getCollection("blog", ({ data }) => !data.draft)),
    ...(await getCollection("essays", ({ data }) => !data.draft)),
    ...(await getCollection("research", ({ data }) => !data.draft)),
    ...(await getCollection("projects", ({ data }) => !data.draft)),
    ...(await getCollection("tools", ({ data }) => !data.draft)),
    ...(await getCollection("photos", ({ data }) => !data.draft)),
    ...(await getCollection("routes", ({ data }) => !data.draft && data.published !== false)),
  ];

  // Build per-locale tag sets
  const tagsByLocale: Record<string, Set<string>> = {};
  for (const locale of locales) tagsByLocale[locale] = new Set();

  for (const entry of allContent) {
    const entryLocale = entry.data.lang ?? "zh-CN";
    for (const t of entry.data.tags) {
      tagsByLocale[entryLocale].add(
        t.toLowerCase().trim().replace(/\s+/g, "-"),
      );
    }
  }

  const result: any[] = [];
  for (const locale of locales) {
    for (const tag of tagsByLocale[locale]) {
      result.push({ params: { locale, tag } });
    }
  }
  return result;
}

const { tag } = Astro.params;
const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);
const dateLocale = locale === "zh-CN" ? "zh-CN" : "en-US";

const allContent = [
  ...(await getCollection("blog", ({ data }) => !data.draft)),
  ...(await getCollection("essays", ({ data }) => !data.draft)),
  ...(await getCollection("research", ({ data }) => !data.draft)),
  ...(await getCollection("projects", ({ data }) => !data.draft)),
  ...(await getCollection("tools", ({ data }) => !data.draft)),
  ...(await getCollection("photos", ({ data }) => !data.draft)),
  ...(await getCollection("routes", ({ data }) => !data.draft && data.published !== false)),
];

const filtered = allContent
  .filter((entry) => (entry.data.lang ?? "zh-CN") === locale)
  .filter((entry) =>
    entry.data.tags.some(
      (t) => t.toLowerCase().trim().replace(/\s+/g, "-") === tag,
    ),
  )
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const displayTag = tag.replace(/-/g, " ");
---

<BaseLayout
  title={`#${displayTag}`}
  description={`Posts tagged with ${displayTag}`}
>
  <div class="page-container py-16 md:py-24">
    <header class="mb-12">
      <h1
        class="text-4xl font-bold tracking-tight text-gray-900 md:text-5xl dark:text-gray-100"
      >
        <span class="text-blue-600 dark:text-blue-400">#</span>
        {displayTag}
      </h1>
      <p class="mt-3 text-lg text-gray-400 dark:text-gray-500">
        {t.tagsPostCount(filtered.length)}
      </p>
    </header>

    {
      filtered.length === 0 ? (
        <p class="text-gray-400 dark:text-gray-500">{t.tagsNoPosts}</p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {filtered.map((entry) => (
            <a
              href={localizePath(`/${entry.collection === "routes" ? "map" : entry.collection}/${entry.slug}`, locale)}
              class="group flex flex-col rounded-xl border border-gray-100 bg-white p-6 no-underline shadow-card transition-all duration-200 hover:border-gray-200 hover:shadow-card-hover dark:border-gray-800 dark:bg-gray-900 dark:hover:border-gray-700"
            >
              <div class="mb-3">
                <span class="rounded-md bg-gray-50 px-2 py-0.5 text-xs font-medium uppercase text-gray-500 dark:bg-gray-800 dark:text-gray-400">
                  {entry.collection === "routes" ? "map" : entry.collection}
                </span>
              </div>
              <h2 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2 dark:text-gray-100 dark:group-hover:text-blue-400">
                {entry.data.title}
              </h2>
              {entry.data.description && (
                <p class="mt-2 flex-1 text-sm text-gray-500 line-clamp-2">
                  {entry.data.description}
                </p>
              )}
              <div class="mt-4 text-xs text-gray-400">
                <time datetime={entry.data.date.toISOString()}>
                  {entry.data.date.toLocaleDateString(dateLocale, {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>

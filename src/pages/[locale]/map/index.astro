---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MapExplorer from "../../../components/MapExplorer.astro";
import { getCollection } from "astro:content";
import {
  getTranslations,
  localizePath,
  type Locale,
  locales,
} from "../../../i18n/utils";
import {
  formatDistance,
  formatDuration,
  getRouteCoordinates,
  getRouteFile,
  isRouteVisible,
  normalizeRouteEntries,
} from "../../../lib/routes/content";

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);
const dateLocale = locale === "zh-CN" ? "zh-CN" : "en-US";

const routes = await getCollection("routes", ({ data }) => isRouteVisible(data));
const entries = normalizeRouteEntries(routes)
  .filter((entry) => (entry.data.lang ?? "zh-CN") === locale)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const kindLabel: Record<string, string> = {
  run: t.mapKindRun,
  hike: t.mapKindHike,
  ride: t.mapKindRide,
  travel: t.mapKindTravel,
  "photo-walk": t.mapKindPhotoWalk,
};

const kindAccent: Record<string, string> = {
  run: "#ff5d8f",
  hike: "#36d399",
  ride: "#4ca9ff",
  travel: "#8b6cff",
  "photo-walk": "#ff9d4d",
};

const items = entries.map((entry) => {
  const data = entry.data;
  const kind = data.kind ?? "travel";
  return {
    slug: entry.slug,
    title: data.title,
    description: data.description,
    date: data.date.toISOString(),
    dateLabel: data.date.toLocaleDateString(dateLocale, {
      year: "numeric",
      month: "short",
      day: "numeric",
    }),
    kind,
    kindLabel: kindLabel[kind] ?? kind,
    location: data.location,
    distance: formatDistance(data.distance),
    duration: formatDuration(data.duration, locale),
    coordinates: getRouteCoordinates(data),
    route: [],
    gpx: getRouteFile(data),
    mapZoom: data.mapZoom,
    accent: data.accent ?? kindAccent[kind] ?? "#5271ff",
    url: localizePath(`/map/${entry.slug}`, locale),
  };
});
---

<BaseLayout title={t.mapPageTitle} description={t.mapPageDescription} mapStyles={true}>
  <div class="map-page">
    <header class="map-page-header page-container">
      <span class="section-kicker">{t.navMap}</span>
      <h1>{t.mapPageTitle}</h1>
      <p>{t.mapPageDescription}</p>
    </header>

    <MapExplorer
      items={items}
      locale={locale}
      labels={{
        all: locale === "zh-CN" ? "全部" : "All",
        explore: locale === "zh-CN" ? "探索足迹" : "Explore journeys",
        empty: t.mapEmpty,
        details: locale === "zh-CN" ? "查看完整记录" : "View full story",
        distance: t.mapDistance,
        duration: t.mapDuration,
        mapped: locale === "zh-CN" ? "个已标记地点" : "mapped places",
      }}
    />
  </div>
</BaseLayout>

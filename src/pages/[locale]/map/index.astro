---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getTranslations, localizePath, type Locale, locales } from "../../../i18n/utils";

export async function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);
const dateLocale = locale === "zh-CN" ? "zh-CN" : "en-US";

const entries = (await getCollection("map", ({ data }) => !data.draft))
  .filter((entry) => (entry.data.lang ?? "zh-CN") === locale)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const kindLabel: Record<string, string> = {
  run: t.mapKindRun,
  hike: t.mapKindHike,
  ride: t.mapKindRide,
  travel: t.mapKindTravel,
  "photo-walk": t.mapKindPhotoWalk,
};
---

<BaseLayout title={t.mapPageTitle} description={t.mapPageDescription}>
  <div class="page-container py-16 md:py-24">
    <header class="mb-12 max-w-3xl">
      <p class="text-sm font-medium uppercase text-gray-500 dark:text-gray-400">{t.navMap}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-100 md:text-5xl">
        {t.mapPageTitle}
      </h1>
      <p class="mt-4 text-lg leading-8 text-gray-500 dark:text-gray-400">{t.mapPageDescription}</p>
    </header>

    {entries.length === 0 ? (
      <p class="text-gray-400">{t.mapEmpty}</p>
    ) : (
      <div class="relative space-y-4 before:absolute before:left-4 before:top-2 before:h-full before:w-px before:bg-gray-200 dark:before:bg-gray-800">
        {entries.map((entry) => (
          <a href={localizePath(`/map/${entry.slug}`, locale)} class="group relative block rounded-lg border border-gray-200 bg-white p-5 pl-12 no-underline transition-colors hover:border-gray-300 hover:bg-gray-50/70 dark:border-gray-800 dark:bg-gray-950 dark:hover:border-gray-700 dark:hover:bg-gray-900/50">
            <span class="absolute left-[11px] top-6 h-3 w-3 rounded-full border-2 border-white bg-blue-500 dark:border-gray-950"></span>
            <div class="flex flex-wrap items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
              <span class="rounded-md bg-gray-100 px-2 py-1 dark:bg-gray-800">{kindLabel[entry.data.kind]}</span>
              <time datetime={entry.data.date.toISOString()}>{entry.data.date.toLocaleDateString(dateLocale, { year: "numeric", month: "short", day: "numeric" })}</time>
              <span>{entry.data.location}</span>
            </div>
            <h2 class="mt-3 text-xl font-semibold text-gray-900 transition-colors group-hover:text-blue-600 dark:text-gray-100">{entry.data.title}</h2>
            {entry.data.description && <p class="mt-2 line-clamp-2 text-sm leading-6 text-gray-500 dark:text-gray-400">{entry.data.description}</p>}
            <div class="mt-4 flex flex-wrap gap-3 text-sm text-gray-500 dark:text-gray-400">
              {entry.data.distance && <span>{t.mapDistance}: {entry.data.distance}</span>}
              {entry.data.duration && <span>{t.mapDuration}: {entry.data.duration}</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

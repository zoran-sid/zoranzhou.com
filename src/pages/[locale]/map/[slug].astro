---
import { getCollection } from "astro:content";
import RouteMap from "../../../components/RouteMap.astro";
import RoutePostLayout from "../../../layouts/RoutePostLayout.astro";
import {
  getRouteCoordinates,
  getRouteEnd,
  getRouteFile,
  getRouteStart,
  isRouteVisible,
  normalizeRouteEntries,
  type RouteContentEntry,
} from "../../../lib/routes/content";

export async function getStaticPaths() {
  const routes = await getCollection("routes", ({ data }) =>
    isRouteVisible(data),
  );
  return normalizeRouteEntries(routes).map((entry) => ({
    params: { locale: entry.data.lang ?? "zh-CN", slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: RouteContentEntry };
const data = entry.data as RouteContentEntry["data"] & Record<string, unknown>;
const gpx = getRouteFile(data);
const coordinates = getRouteCoordinates(data);
const start = getRouteStart(data);
const end = getRouteEnd(data);
const locale = (data.lang ?? "zh-CN") as "zh-CN" | "en";
const accentByKind: Record<string, string> = {
  run: "#ff5d8f",
  hike: "#36d399",
  ride: "#4ca9ff",
  travel: "#8b6cff",
  "photo-walk": "#ff9d4d",
};
const routeAccent =
  data.accent ?? accentByKind[data.kind ?? "travel"] ?? "#36d399";
---

<RoutePostLayout entry={entry}>
  <RouteMap
    slot="route-visual"
    title={data.title}
    gpx={gpx}
    displayGeometry={data.displayGeometry as string | undefined}
    coordinates={coordinates}
    start={start}
    end={end}
    accent={routeAccent}
    locale={locale}
  />
</RoutePostLayout>

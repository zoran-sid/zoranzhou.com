---
import "maplibre-gl/dist/maplibre-gl.css";
import BlogPostLayout from "../../../layouts/BlogPostLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("map", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { locale: entry.data.lang ?? "zh-CN", slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { routeFile, coordinates } = entry.data;
---

<BlogPostLayout entry={entry}>
  {
    routeFile && (
      <div slot="pre-content" class="map-detail-container">
        <div
          id="map-detail"
          class="map-detail-map"
          data-route-file={routeFile}
          data-coordinates={coordinates ? JSON.stringify(coordinates) : ""}
        ></div>
      </div>
    )
  }
</BlogPostLayout>

<script>
  import maplibregl, { LngLatBounds } from "maplibre-gl";

  const container = document.getElementById("map-detail");
  if (container) {
    const routeFile = container.dataset.routeFile;
    const coordsRaw = container.dataset.coordinates;
    const coordinates = coordsRaw ? JSON.parse(coordsRaw) : null;
    const isDark = document.documentElement.classList.contains("dark");
    const lightStyle =
      "https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json";
    const darkStyle =
      "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json";

    const map = new maplibregl.Map({
      container: "map-detail",
      style: isDark ? darkStyle : lightStyle,
      center: coordinates
        ? [coordinates.lng, coordinates.lat]
        : [120.15, 30.27],
      zoom: 13,
      attributionControl: false,
    });

    map.addControl(
      new maplibregl.NavigationControl({ showCompass: false }),
      "bottom-right",
    );
    map.addControl(
      new maplibregl.AttributionControl({ compact: true }),
      "bottom-right",
    );

    map.on("load", async () => {
      if (!routeFile) return;

      try {
        const response = await fetch(routeFile);
        if (!response.ok) return;
        const text = await response.text();

        let points: { lat: number; lng: number }[] = [];

        if (routeFile.toLowerCase().endsWith(".gpx")) {
          const xml = new DOMParser().parseFromString(text, "application/xml");
          points = [...xml.querySelectorAll("trkpt, rtept")]
            .map((point) => ({
              lat: Number(point.getAttribute("lat")),
              lng: Number(point.getAttribute("lon")),
            }))
            .filter(
              (p) => Number.isFinite(p.lat) && Number.isFinite(p.lng),
            );
        } else {
          const geojson = JSON.parse(text);
          const geometry =
            geojson.type === "FeatureCollection"
              ? geojson.features?.find(
                  (f: { geometry?: { type?: string } }) =>
                    f.geometry?.type === "LineString",
                )?.geometry
              : geojson.type === "Feature"
                ? geojson.geometry
                : geojson;
          if (geometry?.type === "LineString") {
            points = geometry.coordinates.map(
              ([lng, lat]: [number, number]) => ({ lat, lng }),
            );
          }
        }

        if (points.length < 2) return;

        const accent = "#36d399";

        map.addSource("route", {
          type: "geojson",
          data: {
            type: "Feature",
            properties: {},
            geometry: {
              type: "LineString",
              coordinates: points.map((p) => [p.lng, p.lat]),
            },
          },
        });

        map.addLayer({
          id: "route-glow",
          type: "line",
          source: "route",
          paint: {
            "line-color": accent,
            "line-width": 10,
            "line-opacity": 0.13,
            "line-blur": 5,
          },
        });

        map.addLayer({
          id: "route-line",
          type: "line",
          source: "route",
          paint: {
            "line-color": accent,
            "line-width": 3.5,
            "line-opacity": 0.9,
          },
        });

        const bounds = new LngLatBounds();
        points.forEach((p) => bounds.extend([p.lng, p.lat]));
        map.fitBounds(bounds, { padding: 60, maxZoom: 15, duration: 1000 });
      } catch (err) {
        console.warn("Failed to load route:", err);
      }
    });

    const themeObserver = new MutationObserver(() => {
      const nextDark = document.documentElement.classList.contains("dark");
      map.setStyle(nextDark ? darkStyle : lightStyle);
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  }
</script>

<style>
  .map-detail-container {
    margin: 0 auto;
    max-width: 900px;
    padding: 0 1rem;
  }
  .map-detail-map {
    width: 100%;
    height: 400px;
    border-radius: 1rem;
    overflow: hidden;
    margin-bottom: 2rem;
  }
  @media (min-width: 768px) {
    .map-detail-map {
      height: 500px;
    }
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { PAGINATION } from "../../lib/constants";

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const sorted = posts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return paginate(sorted, { pageSize: PAGINATION.pageSize });
}

const { page } = Astro.props;
---

<BaseLayout title="Blog" description="Thoughts, tutorials, and personal notes.">
  <div class="page-container py-16 md:py-24">
    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 md:text-5xl dark:text-gray-100">Blog</h1>
      <p class="mt-3 text-lg text-gray-500 dark:text-gray-400">Thoughts, tutorials, and personal notes.</p>
    </header>

    {
      page.data.length === 0 ? (
        <p class="text-gray-400 dark:text-gray-500">No articles yet.</p>
      ) : (
        <div class="divide-y divide-gray-100 dark:divide-gray-800">
          {page.data.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col gap-3 py-6 no-underline transition-all duration-200 hover:bg-gray-50/40 dark:hover:bg-gray-800/30 -mx-4 px-4 rounded-xl sm:flex-row sm:items-baseline sm:gap-8"
            >
              <!-- Date + meta column -->
              <div class="flex shrink-0 items-center gap-3 sm:w-44 sm:flex-col sm:items-start sm:gap-1">
                <time datetime={post.data.date.toISOString()} class="text-sm font-medium text-gray-900 dark:text-gray-200">
                  {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
                </time>
                <span class="text-xs text-gray-400 dark:text-gray-500">
                  {Math.max(1, Math.ceil((post.body ?? "").split(/\s+/).length / 200))} min read
                </span>
              </div>

              <!-- Content column -->
              <div class="min-w-0 flex-1">
                <h2 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors dark:text-gray-100 dark:group-hover:text-blue-400">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="mt-1 text-sm text-gray-500 line-clamp-2 dark:text-gray-400">
                    {post.data.description}
                  </p>
                )}
                {post.data.tags.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1.5">
                    {post.data.tags.slice(0, 4).map((tag) => (
                      <span class="rounded-md bg-gray-100 px-2 py-0.5 text-xs text-gray-500 dark:bg-gray-800 dark:text-gray-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      )
    }

    {page.total > 1 && (
      <nav class="mt-14 flex items-center justify-between">
        {page.prevUrl ? (
          <a href={page.prevUrl} class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 hover:border-blue-300 hover:text-blue-600 transition-colors no-underline dark:border-gray-700 dark:text-gray-400 dark:hover:border-blue-600 dark:hover:text-blue-400">
            ← Previous
          </a>
        ) : <div />}
        <span class="text-sm text-gray-400 dark:text-gray-500">Page {page.currentPage} of {page.total}</span>
        {page.nextUrl ? (
          <a href={page.nextUrl} class="rounded-lg border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 hover:border-blue-300 hover:text-blue-600 transition-colors no-underline dark:border-gray-700 dark:text-gray-400 dark:hover:border-blue-600 dark:hover:text-blue-400">
            Next →
          </a>
        ) : <div />}
      </nav>
    )}
  </div>
</BaseLayout>

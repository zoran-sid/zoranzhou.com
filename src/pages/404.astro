---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Not Found">
  <div class="content-container flex flex-col items-center justify-center py-32 text-center">
    <p class="text-8xl font-bold text-gray-200">404</p>
    <p class="mt-4 text-lg text-gray-500">Page not found.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-medium text-white no-underline transition-colors hover:bg-gray-800"
    >
      ← Back to Home
    </a>
  </div>
</BaseLayout>

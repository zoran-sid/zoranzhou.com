---
import BaseLayout from "./BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { getTranslations, localizePath, type Locale } from "../i18n/utils";

type ContentCollection =
  | "blog"
  | "essays"
  | "research"
  | "projects"
  | "tools"
  | "homelab"
  | "gear"
  | "photos"
  | "map";

interface Props {
  entry: CollectionEntry<ContentCollection>;
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

// ── Reading time ──
const wordCount = (entry.body ?? "").trim().split(/\s+/).length;
const minutes = Math.max(1, Math.ceil(wordCount / 200));

// ── TOC from headings (h2 + h3) ──
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3);

// ── Related articles ──
const allInCollection = await getCollection(
  entry.collection as ContentCollection,
  ({ data }) => !data.draft && (data.lang ?? "zh-CN") === locale,
);
const related = allInCollection
  .filter(
    (e) =>
      e.slug !== entry.slug &&
      e.data.tags.some((t: string) => entry.data.tags.includes(t)),
  )
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// ── Prev / Next ──
const sorted = allInCollection.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const idx = sorted.findIndex((e) => e.slug === entry.slug);
const prevEntry = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const nextEntry = idx > 0 ? sorted[idx - 1] : null;

const labelMap: Record<string, string> = {
  blog: t.navBlog,
  essays: t.navEssays,
  research: t.navResearch,
  projects: t.navProjects,
  tools: t.navTools,
  homelab: t.navHomelab,
  gear: t.navGear,
  photos: t.navPhotos,
  map: t.navMap,
};

const dateLocale = locale === "zh-CN" ? "zh-CN" : "en-US";

// ── JSON-LD Article + BreadcrumbList schema ──
const siteUrl = (Astro.site ?? "https://zoranzhou.com").href.replace(/\/$/, "");
const articleUrl = new URL(localizePath(`/${entry.collection}/${entry.slug}`, locale), Astro.site).href;
const collectionUrl = new URL(localizePath(`/${entry.collection}`, locale), Astro.site).href;
const homeUrl = new URL(localizePath("/", locale), Astro.site).href;
const jsonld = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      headline: entry.data.title,
      description: entry.data.description ?? "",
      author: { "@type": "Person", name: entry.data.author ?? "Zoran Zhou" },
      datePublished: entry.data.date.toISOString(),
      dateModified: entry.data.updated?.toISOString() ?? entry.data.date.toISOString(),
      url: articleUrl,
      ...(entry.data.cover?.src ? { image: new URL(entry.data.cover.src, Astro.site).href } : {}),
      ...(entry.data.tags.length > 0 ? { keywords: entry.data.tags.join(", ") } : {}),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "ZORAN ZHOU", item: homeUrl },
        { "@type": "ListItem", position: 2, name: labelMap[entry.collection] ?? entry.collection, item: collectionUrl },
        { "@type": "ListItem", position: 3, name: entry.data.title },
      ],
    },
  ],
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={entry.data.cover?.src}
  article={true}
  jsonld={jsonld}
>
  <article class="content-container py-12 md:py-16">
    <header class="mb-10">
      <!-- Breadcrumb -->
      <nav class="mb-4 flex items-center gap-1.5 text-sm text-gray-400" aria-label="Breadcrumb">
        <a href={localizePath("/", locale)} class="no-underline hover:text-blue-600 transition-colors">ZORAN ZHOU</a>
        <span class="text-gray-300 dark:text-gray-600">/</span>
        <a
          href={localizePath(`/${entry.collection}`, locale)}
          class="font-medium text-blue-600 no-underline hover:text-blue-700"
        >
          {labelMap[entry.collection] ?? entry.collection}
        </a>
      </nav>

      <h1 class="text-4xl font-bold tracking-tight text-gray-900 md:text-5xl">
        {entry.data.title}
      </h1>

      {entry.data.description && (
        <p class="mt-4 text-lg leading-relaxed text-gray-500">
          {entry.data.description}
        </p>
      )}

      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-gray-400">
        {entry.data.author && <span>{entry.data.author}</span>}
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString(dateLocale, {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {entry.data.updated && (
          <span>
            · {t.postUpdated}{" "}
            <time datetime={entry.data.updated.toISOString()}>
              {entry.data.updated.toLocaleDateString(dateLocale, {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </span>
        )}
        <span>· {minutes} {t.postMinRead}</span>
        <span>· {wordCount} {t.postWords}</span>
      </div>

      {entry.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <a
              href={localizePath(`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`, locale)}
              class="rounded-md border border-gray-200 bg-white px-2.5 py-1 text-xs font-medium text-gray-500 no-underline transition-colors hover:border-gray-300 hover:text-blue-600"
            >
              {tag}
            </a>
          ))}
        </div>
      )}

      {tocItems.length > 0 && (
        <nav class="mt-8 rounded-xl border border-gray-100 bg-gray-50/50 p-5">
          <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-gray-400">
            {t.postTableOfContents}
          </p>
          <ul class="space-y-1.5">
            {tocItems.map((h) => (
              <li>
                <a
                  href={`#${h.slug}`}
                  class={`text-sm text-gray-500 no-underline transition-colors hover:text-blue-600 ${
                    h.depth === 3 ? "pl-4" : ""
                  }`}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="mt-16 border-t border-gray-100 pt-10">
      {(prevEntry || nextEntry) && (
        <nav class="mb-12 grid gap-4 sm:grid-cols-2">
          {prevEntry ? (
            <a
              href={localizePath(`/${entry.collection}/${prevEntry.slug}`, locale)}
              class="group rounded-xl border border-gray-100 p-4 no-underline transition-all hover:border-gray-200 hover:shadow-sm"
            >
              <span class="text-xs text-gray-400">{t.postPrevious}</span>
              <p class="mt-1 text-sm font-medium text-gray-700 group-hover:text-blue-600 transition-colors line-clamp-2">
                {prevEntry.data.title}
              </p>
            </a>
          ) : (
            <div />
          )}
          {nextEntry ? (
            <a
              href={localizePath(`/${entry.collection}/${nextEntry.slug}`, locale)}
              class="group rounded-xl border border-gray-100 p-4 text-right no-underline transition-all hover:border-gray-200 hover:shadow-sm"
            >
              <span class="text-xs text-gray-400">{t.postNext}</span>
              <p class="mt-1 text-sm font-medium text-gray-700 group-hover:text-blue-600 transition-colors line-clamp-2">
                {nextEntry.data.title}
              </p>
            </a>
          ) : (
            <div />
          )}
        </nav>
      )}

      {related.length > 0 && (
        <div>
          <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-400">
            {t.postRelatedArticles}
          </p>
          <div class="grid gap-3 sm:grid-cols-3">
            {related.map((r) => (
              <a
                href={localizePath(`/${entry.collection}/${r.slug}`, locale)}
                class="group rounded-xl border border-gray-100 p-4 no-underline transition-all hover:border-gray-200 hover:shadow-sm"
              >
                <p class="text-sm font-medium text-gray-700 group-hover:text-blue-600 transition-colors line-clamp-2">
                  {r.data.title}
                </p>
                <p class="mt-1 text-xs text-gray-400">
                  {r.data.date.toLocaleDateString(dateLocale, {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}
    </footer>
  </article>
</BaseLayout>

---
import BaseLayout from "./BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { getTranslations, localizePath, type Locale } from "../i18n/utils";
import StarRating from "../components/media/StarRating.astro";

type MediaCollection = "movies" | "tv" | "books" | "games";

interface Props {
  entry: CollectionEntry<MediaCollection>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

const categoryLabelMap: Record<string, string> = {
  movies: t.mediaCategoryMovies,
  tv: t.mediaCategoryTV,
  books: t.mediaCategoryBooks,
  games: t.mediaCategoryGames,
};

const statusLabelMap: Record<string, string> = {
  watched: t.mediaStatusWatched,
  watching: t.mediaStatusWatching,
  "want-to-watch": t.mediaStatusWantToWatch,
  completed: t.mediaStatusCompleted,
  playing: t.mediaStatusPlaying,
  "want-to-play": t.mediaStatusWantToPlay,
  read: t.mediaStatusRead,
  reading: t.mediaStatusReading,
  "want-to-read": t.mediaStatusWantToRead,
  dropped: t.mediaStatusDropped,
  "on-hold": t.mediaStatusOnHold,
};

// ── Related ──
const allInCollection = await getCollection(
  entry.collection as MediaCollection,
  ({ data }) => !data.draft && (data.lang ?? "zh-CN") === locale,
);
const related = allInCollection
  .filter(
    (e) =>
      e.slug !== entry.slug &&
      e.data.genres.some((g: string) => (entry.data.genres ?? []).includes(g)),
  )
  .slice(0, 4);

// ── Next / Previous ──
const sorted = allInCollection.sort(
  (a, b) => (b.data.watchedDate ?? new Date(0)).valueOf() - (a.data.watchedDate ?? new Date(0)).valueOf(),
);
const idx = sorted.findIndex((e) => e.slug === entry.slug);
const prevEntry = idx < sorted.length - 1 ? sorted[idx + 1] : null;
const nextEntry = idx > 0 ? sorted[idx - 1] : null;

const dateLocaleStr = locale === "zh-CN" ? "zh-CN" : "en-US";
const siteUrl = (Astro.site ?? "https://zoranzhou.com").href.replace(/\/$/, "");

// ── JSON-LD ──
const articleUrl = new URL(
  localizePath(`/media/${entry.collection === "tv" ? "tv" : entry.collection === "books" ? "book" : entry.collection === "games" ? "game" : "movie"}/${entry.slug}`, locale),
  Astro.site,
).href;
const mediaUrl = new URL(localizePath("/media", locale), Astro.site).href;
const homeUrl = new URL(localizePath("/", locale), Astro.site).href;
const jsonld = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": entry.collection === "books" ? "Book" : entry.collection === "movies" ? "Movie" : "CreativeWork",
      name: entry.data.title,
      description: entry.data.summary ?? "",
      ...(entry.data.originalTitle ? { alternateName: entry.data.originalTitle } : {}),
      ...(entry.data.author ? { author: { "@type": "Person", name: entry.data.author } } : {}),
      ...(entry.data.director ? { director: { "@type": "Person", name: entry.data.director } } : {}),
      dateCreated: entry.data.year ? String(entry.data.year) : undefined,
      url: articleUrl,
      ...(entry.data.poster ? { image: new URL(entry.data.poster, Astro.site).href } : {}),
      ...(entry.data.genres.length > 0 ? { genre: entry.data.genres } : {}),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "ZORAN ZHOU", item: homeUrl },
        { "@type": "ListItem", position: 2, name: t.mediaTitle, item: mediaUrl },
        { "@type": "ListItem", position: 3, name: categoryLabelMap[entry.collection] ?? entry.collection },
        { "@type": "ListItem", position: 4, name: entry.data.title },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${entry.data.title} — ${t.mediaTitle}`}
  description={entry.data.summary ?? `${t.mediaTitle} — ${entry.data.title}`}
  ogImage={entry.data.poster ?? entry.data.cover}
  article={true}
  jsonld={jsonld}
>
  <article>
    <!-- Hero Banner -->
    <header class="relative overflow-hidden surface-hero">
      <!-- Background cover image with blur overlay -->
      {entry.data.cover && (
        <div class="absolute inset-0">
          <img
            src={entry.data.cover}
            alt=""
            class="h-full w-full object-cover opacity-20 blur-2xl scale-110"
            loading="eager"
            aria-hidden="true"
          />
          <div class="absolute inset-0 bg-gradient-to-b from-white/60 via-white/40 to-white dark:from-[#0a0a0b]/80 dark:via-[#0a0a0b]/60 dark:to-[#0a0a0b]"></div>
        </div>
      )}

      <div class="page-container relative z-10 py-16 md:py-24">
        <!-- Breadcrumb -->
        <nav class="mb-6 flex items-center gap-1.5 text-sm text-gray-400" aria-label="Breadcrumb">
          <a href={localizePath("/", locale)} class="no-underline hover:text-blue-600 transition-colors">ZORAN ZHOU</a>
          <span class="text-gray-300 dark:text-gray-600">/</span>
          <a href={localizePath("/media", locale)} class="no-underline hover:text-blue-600 transition-colors">{t.mediaTitle}</a>
          <span class="text-gray-300 dark:text-gray-600">/</span>
          <span class="text-gray-500 dark:text-gray-400">{categoryLabelMap[entry.collection] ?? entry.collection}</span>
        </nav>

        <div class="flex flex-col gap-8 md:flex-row md:items-start md:gap-12">
          <!-- Poster -->
          {entry.data.poster && (
            <div class="shrink-0">
              <img
                src={entry.data.poster}
                alt={`${entry.data.title} poster`}
                class="w-40 rounded-xl shadow-elevated md:w-52"
                loading="eager"
                width="208"
                height="312"
              />
            </div>
          )}

          <!-- Metadata -->
          <div class="flex-1 min-w-0">
            <div class="mb-3">
              <span class="inline-block rounded-full border border-gray-200/80 bg-white/70 px-3 py-1 text-xs font-medium text-gray-600 shadow-card backdrop-blur-md dark:border-white/10 dark:bg-white/5 dark:text-gray-300">
                {categoryLabelMap[entry.collection] ?? entry.collection}
              </span>
            </div>

            <h1 class="text-3xl font-bold tracking-tight text-gray-900 md:text-4xl lg:text-5xl dark:text-gray-100">
              {entry.data.title}
            </h1>

            {entry.data.originalTitle && (
              <p class="mt-2 text-lg text-gray-400 dark:text-gray-500">
                {entry.data.originalTitle}
              </p>
            )}

            <!-- Rating -->
            <div class="mt-4 flex items-center gap-3">
              <StarRating rating={entry.data.rating} size="lg" />
              {entry.data.rating > 0 && (
                <span class="text-sm font-medium text-gray-500 dark:text-gray-400">
                  {entry.data.rating}/5
                </span>
              )}
            </div>

            <!-- Summary -->
            {entry.data.summary && (
              <p class="mt-5 max-w-2xl text-base leading-relaxed text-gray-600 dark:text-gray-400">
                {entry.data.summary}
              </p>
            )}

            <!-- Quick facts grid -->
            <div class="mt-6 grid grid-cols-2 gap-x-6 gap-y-3 sm:grid-cols-3 lg:grid-cols-4">
              {entry.data.year && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">Year</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">{entry.data.year}</dd>
                </div>
              )}
              {(entry.data.director || entry.data.author || entry.data.developer) && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">
                    {entry.data.director ? t.mediaDirector : entry.data.author ? t.mediaAuthor : t.mediaDeveloper}
                  </dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">
                    {entry.data.director ?? entry.data.author ?? entry.data.developer}
                  </dd>
                </div>
              )}
              {entry.data.country && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{t.mediaCountry}</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">{entry.data.country}</dd>
                </div>
              )}
              {entry.data.genres.length > 0 && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{t.mediaGenres}</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">
                    {entry.data.genres.join(" · ")}
                  </dd>
                </div>
              )}
              {entry.data.runtime && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{t.mediaRuntime}</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">{entry.data.runtime}</dd>
                </div>
              )}
              {entry.data.language && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{t.mediaLanguage}</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">{entry.data.language}</dd>
                </div>
              )}
              {entry.data.status && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">Status</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">
                    {statusLabelMap[entry.data.status] ?? entry.data.status}
                  </dd>
                </div>
              )}
              {entry.data.watchedDate && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{t.mediaWatchedDate}</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">
                    {entry.data.watchedDate.toLocaleDateString(dateLocaleStr, { year: "numeric", month: "short", day: "numeric" })}
                  </dd>
                </div>
              )}
              {"seasons" in entry.data && entry.data.seasons && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{t.mediaSeasons}</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">{entry.data.seasons}</dd>
                </div>
              )}
              {"pages" in entry.data && entry.data.pages && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{t.mediaPages}</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">{entry.data.pages}</dd>
                </div>
              )}
              {"platform" in entry.data && entry.data.platform && entry.data.platform.length > 0 && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{t.mediaPlatform}</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">
                    {entry.data.platform.join(" · ")}
                  </dd>
                </div>
              )}
              {entry.data.publisher && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">{t.mediaPublisher}</dt>
                  <dd class="mt-0.5 text-sm font-medium text-gray-800 dark:text-gray-200">{entry.data.publisher}</dd>
                </div>
              )}
            </div>

            {entry.data.tags.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-1.5">
                {entry.data.tags.map((tag) => (
                  <span class="rounded-md bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-500 dark:bg-gray-800 dark:text-gray-400">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </header>

    <!-- Review Content -->
    <div class="page-container py-12 md:py-16">
      <div class="prose content-container max-w-none">
        <Content />
      </div>
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <section class="surface-writing py-16 md:py-20">
        <div class="page-container">
          <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-gray-100">{t.mediaRelated}</h2>
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {related.map((item) => (
              <a
                href={localizePath(
                  `/media/${entry.collection === "tv" ? "tv" : entry.collection === "books" ? "book" : entry.collection === "games" ? "game" : "movie"}/${item.slug}`,
                  locale,
                )}
                class="group block rounded-xl border border-gray-100 bg-white p-4 no-underline shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover dark:border-gray-800 dark:bg-gray-900"
              >
                {item.data.poster && (
                  <img
                    src={item.data.poster}
                    alt={item.data.title}
                    class="mb-3 w-full rounded-lg object-cover aspect-[2/3]"
                    loading="lazy"
                  />
                )}
                <h3 class="text-sm font-semibold text-gray-900 group-hover:text-blue-600 transition-colors dark:text-gray-100 dark:group-hover:text-blue-400">
                  {item.data.title}
                </h3>
                <div class="mt-1 flex items-center gap-2">
                  <StarRating rating={item.data.rating} size="sm" />
                  {item.data.year && (
                    <span class="text-xs text-gray-400 dark:text-gray-500">{item.data.year}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Back link -->
    <div class="page-container pb-16">
      <a
        href={localizePath("/media", locale)}
        class="inline-flex items-center gap-2 text-sm font-medium text-gray-400 no-underline transition-colors hover:text-blue-600 dark:text-gray-500 dark:hover:text-blue-400"
      >
        {t.mediaBackToMedia}
      </a>
    </div>
  </article>
</BaseLayout>

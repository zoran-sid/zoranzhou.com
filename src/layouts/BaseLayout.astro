---
import "../styles/global.css";
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";
import ThemeScript from "../components/ThemeScript.astro";
import Navigation from "../components/Navigation.astro";
import {
  getTranslations,
  type Locale,
  locales,
  hreflangMap,
  localizePath,
} from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
  jsonld?: Record<string, unknown>;
  alternatePaths?: Partial<Record<Locale, string>>;
  mapStyles?: boolean;
}

const { title, description, ogImage, article = false, jsonld, alternatePaths, mapStyles = false } = Astro.props;

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

const pageTitle = title ? `${title} | ZORAN ZHOU` : "ZORAN ZHOU";
const pageDescription = description ?? t.siteDescription;

// Current page path used for canonical and alternate URLs.
const canonicalPath = Astro.url.pathname;
const pathWithoutLocale = canonicalPath.replace(/^\/(?:zh-CN|en)(?=\/|$)/, "") || "/";
const isListingPath = pathWithoutLocale.split("/").filter(Boolean).length <= 1;
const safeAlternatePaths = alternatePaths ?? (isListingPath
  ? Object.fromEntries(locales.map((item) => [item, localizePath(pathWithoutLocale, item)]))
  : {});
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={new URL(canonicalPath, Astro.site)} />

    <!-- hreflang -->
    {
      locales.map((altLocale) => {
        const altPath = safeAlternatePaths[altLocale];
        if (!altPath) return null;
        return (
          <link
            rel="alternate"
            hreflang={hreflangMap[altLocale]}
            href={new URL(altPath, Astro.site).href}
          />
        );
      })
    }
    <link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site).href} />

    <!-- OpenGraph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:url" content={new URL(canonicalPath, Astro.site)} />
    <meta
      property="og:locale"
      content={locale === "zh-CN" ? "zh_Hans" : "en"}
    />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:site_name" content="ZORAN ZHOU" />

    <!-- Twitter -->
    <meta
      name="twitter:card"
      content={ogImage ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {
      ogImage && (
        <meta
          name="twitter:image"
          content={new URL(ogImage, Astro.site).href}
        />
      )
    }

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="ZORAN ZHOU RSS"
      href={localizePath("/rss.xml", locale)}
    />

    <!-- JSON-LD Structured Data -->
    {
      jsonld && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
      )
    }

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {mapStyles && <link rel="stylesheet" href="/styles/maplibre-gl.css" />}
    {mapStyles && <link rel="stylesheet" href="/styles/map-custom.css" />}

    <ThemeScript />
  </head>
  <body
    class="site-body bg-white text-gray-900 antialiased dark:bg-[#0a0a0b] dark:text-gray-200"
  >
    <div class="site-backdrop" aria-hidden="true">
      <span class="site-backdrop__grid"></span>
      <span class="site-backdrop__glow glow-a"></span>
      <span class="site-backdrop__glow glow-b"></span>
    </div>

    <!-- Scroll progress bar -->
    <div id="progress-bar" class="scroll-progress"></div>

    <Navigation />
    <main class="site-main min-h-screen relative z-[1]">
      <slot />
    </main>

    <!-- Back to top -->
    <button id="back-to-top" class="back-to-top" aria-label="Back to top">
      <svg
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
      </svg>
    </button>
  </body><script>
    const progressBar = document.getElementById("progress-bar");
    const backToTop = document.getElementById("back-to-top");
    const homeSections =
      document.querySelectorAll<HTMLElement>(".home-section");
    const homeExperience = document.querySelector<HTMLElement>(
      "[data-home-experience]",
    );
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    let animationFrame = 0;
    let homeExperienceMetrics: { top: number; height: number } | undefined;
    let sectionMetrics: Array<{ section: HTMLElement; top: number; height: number }> = [];

    function measureScrollSections() {
      const scrollTop = window.scrollY;
      if (homeExperience) {
        const rect = homeExperience.getBoundingClientRect();
        homeExperienceMetrics = { top: rect.top + scrollTop, height: rect.height };
      }
      sectionMetrics = [...homeSections].map((section) => {
        const rect = section.getBoundingClientRect();
        return { section, top: rect.top + scrollTop, height: rect.height };
      });
      requestScrollUpdate();
    }

    function updateScrollEffects() {
      const scrollTop = window.scrollY;
      const docHeight =
        document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? scrollTop / docHeight : 0;
      if (progressBar) progressBar.style.transform = `scaleX(${progress.toFixed(4)})`;

      backToTop?.classList.toggle("visible", scrollTop > 500);

      if (homeExperience && homeExperienceMetrics) {
        const travel = Math.max(1, homeExperienceMetrics.height - window.innerHeight);
        const journeyProgress = Math.min(1, Math.max(0, (scrollTop - homeExperienceMetrics.top) / travel));
        homeExperience.style.setProperty(
          "--journey-progress",
          journeyProgress.toFixed(4),
        );
      }

      if (!reduceMotion) {
        const viewportHeight = window.innerHeight;
        sectionMetrics.forEach(({ section, top, height }) => {
          const sectionProgress = Math.min(
            1,
            Math.max(
              0,
              (viewportHeight - (top - scrollTop)) / (viewportHeight + height),
            ),
          );
          section.style.setProperty(
            "--section-progress",
            sectionProgress.toFixed(3),
          );
        });
      }

      animationFrame = 0;
    }

    function requestScrollUpdate() {
      if (animationFrame) return;
      animationFrame = window.requestAnimationFrame(updateScrollEffects);
    }

    window.addEventListener("scroll", requestScrollUpdate, { passive: true });
    window.addEventListener("resize", measureScrollSections, { passive: true });
    const resizeObserver = new ResizeObserver(measureScrollSections);
    if (homeExperience) resizeObserver.observe(homeExperience);
    document.fonts.ready.then(measureScrollSections);
    measureScrollSections();

    backToTop?.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    const revealElements = document.querySelectorAll(".reveal");
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            entry.target.addEventListener("transitionend", () => entry.target.classList.add("reveal-complete"), { once: true });
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: "0px 0px -7% 0px" },
    );
    revealElements.forEach((el) => revealObserver.observe(el));
  </script>
</html>

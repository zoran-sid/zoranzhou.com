---
import { ABOUT } from "../lib/constants";
---

<section class="home-section surface-about section-lighting texture-dots">
  <div class="page-container">
    <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:gap-24">
      <div class="reveal">
        <span class="section-kicker">About</span>
        <h2 class="section-heading md:max-w-xl">
          {ABOUT.headline}
        </h2>
      </div>

      <div class="reveal premium-card rounded-2xl p-6 md:p-8">
        <div class="space-y-5">
          {ABOUT.paragraphs.map((p) => (
            <p class="text-base leading-relaxed text-gray-600 md:text-lg dark:text-gray-400">
              {p}
            </p>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

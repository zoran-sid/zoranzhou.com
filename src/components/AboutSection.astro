---
import { getTranslations, type Locale } from "../i18n/utils";

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);
---

<section class="home-section surface-about section-lighting texture-dots">
  <div class="page-container">
    <div class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:gap-24">
      <div class="reveal">
        <span class="section-kicker">{t.aboutLabel}</span>
        <h2 class="section-heading md:max-w-xl">{t.aboutHeadline}</h2>
      </div>

      <div class="reveal premium-card rounded-2xl p-6 md:p-8">
        <div class="space-y-5">
          {
            t.aboutParagraphs.map((paragraph) => (
              <p class="text-base leading-relaxed text-gray-600 md:text-lg dark:text-gray-400">
                {paragraph}
              </p>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

---
import { SOCIAL_LINKS, SOCIAL_ICONS, COPYRIGHT, SITE } from "../lib/constants";
---

<footer class="surface-footer border-t border-gray-200/70 dark:border-white/10">
  <div class="page-container py-16 md:py-20">
    <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-sm font-semibold tracking-tight text-gray-900 dark:text-gray-100">{SITE.title}</p>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-500">Building resilient systems, sharing what I learn.</p>
      </div>
      <div class="flex items-center gap-5">
        {SOCIAL_LINKS.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 transition-colors duration-200 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300"
            aria-label={link.label}
          >
            <Fragment set:html={SOCIAL_ICONS[link.name] ?? ""} />
          </a>
        ))}
        <a
          href="/rss.xml"
          class="text-gray-400 transition-colors duration-200 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300"
          aria-label="RSS Feed"
        >
          <Fragment set:html={SOCIAL_ICONS.rss} />
        </a>
      </div>
    </div>
    <div class="mt-10 flex flex-col gap-2 border-t border-gray-200/70 pt-6 text-sm text-gray-400 dark:border-white/10 dark:text-gray-500 sm:flex-row sm:items-center sm:justify-between">
      <span>&copy; {new Date().getFullYear()} {SITE.title}</span>
      <a
        href={COPYRIGHT.licenseUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 transition-colors duration-200 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300"
      >
        {COPYRIGHT.license}
      </a>
    </div>
  </div>
</footer>

---
import type { LabCopy } from "../../i18n/lab";
import { localizePath, type Locale } from "../../i18n/utils";

interface Props {
  locale: Locale;
  copy: LabCopy;
}

const { locale, copy } = Astro.props;
---

<footer class="lab-footer">
  <div class="lab-shell lab-footer__grid">
    <div>
      <span class="lab-footer__brand">WEB3 / LAB</span>
      <p>{copy.footer.boundary}</p>
    </div>
    <div class="lab-footer__links">
      <a href={localizePath("/", locale)}>← {copy.footer.returnToSite}</a>
      <span>© {new Date().getFullYear()} ZORAN ZHOU</span>
    </div>
  </div>
</footer>

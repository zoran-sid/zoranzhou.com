---
import { getCollection } from "astro:content";
import { getTranslations, localizePath, type Locale } from "../i18n/utils";

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

const research = await getCollection("research", ({ data }) => !data.draft);
const featured = research
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section class="home-section surface-research section-lighting texture-grid">
  <div class="page-container">
    <div class="mb-14 flex items-end justify-between gap-8">
      <div class="reveal">
        <span class="section-kicker">{t.researchLabel}</span>
        <h2 class="section-heading">{t.researchHeading}</h2>
        <p class="section-deck">
          {t.researchDeck}
        </p>
      </div>
      <a href={localizePath("/research", locale)} class="premium-link hidden sm:inline-flex">
        {t.researchViewAll}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    {
      featured.length === 0 ? (
        <p class="text-gray-400 dark:text-gray-500">{t.researchEmpty}</p>
      ) : (
        <div class="grid gap-6 md:grid-cols-3">
          {featured.map((entry) => (
            <a href={localizePath(`/research/${entry.slug}`, locale)} class="premium-card reveal group block rounded-2xl p-6 no-underline">
              <div class="mb-6 flex items-center justify-between gap-3">
                <span class="status-chip rounded-full px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.14em]">
                  {entry.data.status?.replace("-", " ") ?? "Completed"}
                </span>
                <span class="h-px flex-1 bg-gray-200/80 dark:bg-white/10"></span>
              </div>
              <h3 class="text-lg font-semibold tracking-tight text-gray-950 transition-colors group-hover:text-gray-700 dark:text-gray-100 dark:group-hover:text-white">
                {entry.data.title}
              </h3>
              {entry.data.description && (
                <p class="mt-3 line-clamp-3 text-sm text-gray-500 dark:text-gray-400">
                  {entry.data.description}
                </p>
              )}
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>

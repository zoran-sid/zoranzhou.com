---
import { getCollection } from "astro:content";
import { getTranslations, localizePath, type Locale } from "../i18n/utils";

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

const research = await getCollection("research", ({ data }) => !data.draft);
const activeResearch = research
  .filter((r) => (r.data.lang ?? "zh-CN") === locale)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const projects = await getCollection("projects", ({ data }) => !data.draft);
const activeProjects = projects
  .filter((p) => (p.data.lang ?? "zh-CN") === locale)
  .filter((p) => p.data.status === "active")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const statusColors: Record<string, string> = {
  "in-progress": "border-amber-200/80 text-amber-700 dark:border-amber-400/25 dark:text-amber-300",
  "completed": "border-green-200/80 text-green-700 dark:border-green-400/25 dark:text-green-300",
  "archived": "border-gray-200/80 text-gray-500 dark:border-white/10 dark:text-gray-400",
  "active": "border-emerald-200/80 text-emerald-700 dark:border-emerald-400/25 dark:text-emerald-300",
};
---

<section class="home-section surface-working section-lighting texture-noise">
  <div class="page-container">
    <div class="mb-14 reveal">
      <span class="section-kicker">{t.workingOnLabel}</span>
      <h2 class="section-heading">{t.workingOnHeading}</h2>
      <p class="section-deck">
        {t.workingOnDeck}
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="premium-card reveal rounded-2xl p-6 md:p-7">
        <h3 class="mb-5 flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.16em] text-gray-500 dark:text-gray-400">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-yellow-400 opacity-50"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-yellow-500"></span>
          </span>
          {t.workingOnResearchQueue}
        </h3>
        <div class="space-y-4">
          {activeResearch.length === 0 ? (
            <p class="text-sm text-gray-400 dark:text-gray-500">{t.workingOnNoActiveResearch}</p>
          ) : (
            activeResearch.map((entry) => (
              <a href={localizePath(`/research/${entry.slug}`, locale)} class="group block rounded-xl border border-gray-200/70 bg-white/45 p-5 no-underline transition-all duration-200 hover:border-gray-300 hover:bg-white/80 dark:border-white/10 dark:bg-white/[0.03] dark:hover:bg-white/[0.06]">
                <div class="mb-2 flex items-center gap-2">
                  <span class={`status-chip rounded-full px-2.5 py-0.5 text-[11px] font-semibold ${statusColors[entry.data.status ?? "completed"]}`}>
                    {(entry.data.status ?? "completed").replace("-", " ")}
                  </span>
                </div>
                <h4 class="text-sm font-semibold text-gray-950 transition-colors group-hover:text-gray-700 dark:text-gray-100 dark:group-hover:text-white">
                  {entry.data.title}
                </h4>
                {entry.data.description && (
                  <p class="mt-1 line-clamp-2 text-xs text-gray-500 dark:text-gray-400">
                    {entry.data.description}
                  </p>
                )}
              </a>
            ))
          )}
        </div>
      </div>

      <div class="premium-card reveal rounded-2xl p-6 md:p-7">
        <h3 class="mb-5 flex items-center gap-3 text-sm font-semibold uppercase tracking-[0.16em] text-gray-500 dark:text-gray-400">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-yellow-400 opacity-50"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-yellow-500"></span>
          </span>
          {t.workingOnBuildQueue}
        </h3>
        <div class="space-y-4">
          {activeProjects.length === 0 ? (
            <p class="text-sm text-gray-400 dark:text-gray-500">{t.workingOnNoActiveProjects}</p>
          ) : (
            activeProjects.map((entry) => (
              <a href={localizePath(`/projects/${entry.slug}`, locale)} class="group block rounded-xl border border-gray-200/70 bg-white/45 p-5 no-underline transition-all duration-200 hover:border-gray-300 hover:bg-white/80 dark:border-white/10 dark:bg-white/[0.03] dark:hover:bg-white/[0.06]">
                <div class="mb-2 flex items-center gap-2">
                  {entry.data.icon && <span class="text-base">{entry.data.icon}</span>}
                  <span class={`status-chip rounded-full px-2.5 py-0.5 text-[11px] font-semibold ${statusColors[entry.data.status ?? "active"]}`}>
                    {entry.data.status ?? "active"}
                  </span>
                </div>
                <h4 class="text-sm font-semibold text-gray-950 transition-colors group-hover:text-gray-700 dark:text-gray-100 dark:group-hover:text-white">
                  {entry.data.title}
                </h4>
                {entry.data.description && (
                  <p class="mt-1 line-clamp-2 text-xs text-gray-500 dark:text-gray-400">
                    {entry.data.description}
                  </p>
                )}
                {entry.data.tech.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {entry.data.tech.slice(0, 4).map((t) => (
                      <span class="skill-chip rounded-md px-2 py-0.5 text-[10px]">
                        {t}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            ))
          )}
        </div>
      </div>
    </div>

    <div class="mt-8 flex flex-wrap gap-5">
      <a href={localizePath("/research", locale)} class="premium-link">
        {t.researchViewAll}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href={localizePath("/projects", locale)} class="premium-link">
        {t.projectsViewAll}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

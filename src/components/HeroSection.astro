---
import { getTranslations, localizePath, type Locale } from "../i18n/utils";

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);
---

<section class="home-section surface-hero hero-scene">
  <div class="hero-coordinates" aria-hidden="true">
    <span>30.2741° N</span><span>120.1551° E</span><span>UTC +08:00</span>
  </div>

  <div class="page-container relative z-10">
    <div class="hero-layout">
      <div class="hero-copy">
        <div class="hero-status">
          <span class="hero-status__pulse"></span>
          <strong>STATUS / ONLINE</strong>
          <i></i>
          <span>{t.heroBadge}</span>
        </div>

        <p class="section-kicker">{t.heroKicker}</p>
        <h1 class="hero-title">
          <span>{t.heroTitleLine1}</span>
          <small>{t.heroTitleLine2}</small>
        </h1>

        <p class="hero-description">{t.heroDescription}</p>

        <div class="hero-actions">
          <a
            href={localizePath("/blog", locale)}
            class="hero-primary-action group"
          >
            <span>{t.heroReadBlog}</span>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 12h14m-5-5 5 5-5 5"></path>
            </svg>
          </a>
          <a href="#contact" class="hero-secondary-action">
            <span>{t.heroGetInTouch}</span><i aria-hidden="true"></i>
          </a>
        </div>

        <div class="hero-disciplines" aria-label="Core disciplines">
          <span><i>01</i>NETWORK</span>
          <span><i>02</i>SECURITY</span>
          <span><i>03</i>RESEARCH</span>
        </div>
      </div>

      <div class="hero-console" aria-label="System profile visualization">
        <header class="hero-console__header">
          <span class="console-lights" aria-hidden="true"
            ><i></i><i></i><i></i></span
          >
          <strong>ZORAN://PROFILE.SYS</strong>
          <span class="console-live"><i></i>LIVE</span>
        </header>

        <div class="hero-console__body">
          <div class="signal-radar" aria-hidden="true">
            <div class="signal-radar__grid"></div>
            <div class="signal-radar__sweep"></div>
            <div class="signal-radar__ring ring-one"></div>
            <div class="signal-radar__ring ring-two"></div>
            <div class="signal-radar__ring ring-three"></div>
            <div class="signal-radar__axis axis-x"></div>
            <div class="signal-radar__axis axis-y"></div>
            <div class="signal-radar__core"><span></span></div>
            <i class="radar-node radar-node-a"></i>
            <i class="radar-node radar-node-b"></i>
            <i class="radar-node radar-node-c"></i>
          </div>

          <dl class="console-readouts">
            <div><dt>ROLE</dt><dd>{t.heroKicker}</dd></div>
            <div><dt>FOCUS</dt><dd>SECURE SYSTEMS</dd></div>
            <div><dt>METHOD</dt><dd>BUILD · TEST · DOCUMENT</dd></div>
            <div>
              <dt>SIGNAL</dt><dd>
                <span class="readout-bars" aria-hidden="true"
                  ><i></i><i></i><i></i><i></i><i></i></span
                >STABLE
              </dd>
            </div>
          </dl>
        </div>

        <footer class="hero-console__footer">
          <span>PACKETS / 2.4K</span><span>LATENCY / 08MS</span><span
            >UPTIME / 99.99%</span
          >
        </footer>
      </div>
    </div>
  </div>
</section>

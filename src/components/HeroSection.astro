---
import { getTranslations, localizePath, type Locale } from "../i18n/utils";

const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);
---

<section
  class="home-section surface-hero section-lighting hero-scene pt-28 md:pt-40"
>
  <div
    class="absolute inset-0 pointer-events-none overflow-hidden"
    aria-hidden="true"
  >
    <div class="gradient-blob blob-1"></div>
    <div class="gradient-blob blob-2"></div>
  </div>

  <div class="page-container relative z-10">
    <div class="hero-layout">
      <div class="hero-copy">
        <div
          class="mb-10 inline-flex items-center gap-2 rounded-full border border-gray-200/80 bg-white/70 px-4 py-1.5 text-sm font-medium text-gray-700 shadow-card backdrop-blur-md dark:border-white/10 dark:bg-white/5 dark:text-gray-300"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-50"
            ></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"
            ></span>
          </span>
          {t.heroBadge}
        </div>

        <p class="section-kicker">{t.heroKicker}</p>
        <h1 class="hero-title mt-5 text-gray-950 dark:text-white">
          <span class="block">{t.heroTitleLine1}</span>
          <span class="hero-title-secondary block">{t.heroTitleLine2}</span>
        </h1>

        <p
          class="mt-8 max-w-2xl text-lg leading-relaxed text-gray-600 md:text-xl dark:text-gray-400"
        >
          {t.heroDescription}
        </p>

        <div class="mt-12 flex flex-wrap gap-4">
          <a
            href={localizePath("/blog", locale)}
            class="hero-primary-action group inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold no-underline"
          >
            {t.heroReadBlog}
            <svg
              class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="#contact"
            class="hero-secondary-action inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold no-underline"
          >
            {t.heroGetInTouch}
          </a>
        </div>
      </div>

      <div class="hero-visual system-field" aria-hidden="true">
        <div class="system-field-grid"></div>
        <div class="system-ring system-ring-outer"></div>
        <div class="system-ring system-ring-middle"></div>
        <div class="system-ring system-ring-inner"></div>
        <div class="system-core"><span></span></div>
        <i class="system-node node-a"></i>
        <i class="system-node node-b"></i>
        <i class="system-node node-c"></i>
        <i class="system-node node-d"></i>
        <div class="system-field-label label-a">RESILIENCE</div>
        <div class="system-field-label label-b">OBSERVABILITY</div>
        <div class="system-field-label label-c">SECURITY</div>
      </div>
    </div>
  </div>
</section>

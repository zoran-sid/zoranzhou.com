---
import { NAV_ITEMS, SITE } from "../lib/constants";
import SearchModal from "../components/SearchModal.tsx";

const path = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-gray-100/60 bg-white/75 backdrop-blur-xl dark:border-gray-800/50 dark:bg-gray-950/75">
  <nav class="page-container flex h-16 items-center justify-between">
    <a
      href="/"
      class="text-base font-semibold tracking-tight text-gray-900 no-underline transition-colors duration-200 hover:text-gray-600 dark:text-gray-100 dark:hover:text-gray-300"
    >
      ZORAN ZHOU
    </a>

    <div class="flex items-center gap-5">
      {NAV_ITEMS.map((item) => {
        const active = path === item.href || path.startsWith(item.href + "/");
        return (
          <a
            href={item.href}
            class={`text-sm font-medium transition-colors duration-200 no-underline ${
              active
                ? "text-gray-900 dark:text-gray-100"
                : "text-gray-400 hover:text-gray-700 dark:text-gray-500 dark:hover:text-gray-300"
            }`}
          >
            {item.label}
          </a>
        );
      })}
      <SearchModal client:load />
      <button
        id="theme-toggle"
        class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100/60 hover:text-gray-600 transition-all duration-200 dark:text-gray-500 dark:hover:bg-gray-800/60 dark:hover:text-gray-300"
        aria-label="Toggle dark mode"
      >
        <!-- sun icon (shown in dark mode) -->
        <svg class="h-5 w-5 hidden dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- moon icon (shown in light mode) -->
        <svg class="h-5 w-5 block dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById("theme-toggle");
  btn?.addEventListener("click", () => {
    const html = document.documentElement;
    const isDark = html.classList.contains("dark");
    if (isDark) {
      html.classList.remove("dark");
      localStorage.setItem("pref-theme", "light");
    } else {
      html.classList.add("dark");
      localStorage.setItem("pref-theme", "dark");
    }
  });
</script>

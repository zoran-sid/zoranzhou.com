---
import SearchModal from "../components/SearchModal.tsx";
import {
  getTranslations,
  type Locale,
  localeLabels,
  locales,
  localizePath,
} from "../i18n/utils";

const path = Astro.url.pathname;
const locale = (Astro.currentLocale ?? "zh-CN") as Locale;
const t = getTranslations(locale);

const primaryNavItems = [
  { label: t.navBlog, href: localizePath("/blog", locale) },
  { label: t.navResearch, href: localizePath("/research", locale) },
  { label: t.navProjects, href: localizePath("/projects", locale) },
  { label: t.navMedia, href: localizePath("/media", locale) },
  { label: t.navEssays, href: localizePath("/essays", locale) },
];

const personalNavItems = [
  { label: t.navPhotos, href: localizePath("/photos", locale), icon: "photos" },
  { label: t.navMap, href: localizePath("/map", locale), icon: "map" },
];
---

<header class="site-header" data-site-header>
  <svg aria-hidden="true" class="hidden">
    <symbol id="nav-icon-photos" viewBox="0 0 24 24">
      <path
        d="M4.75 7.75A2.75 2.75 0 0 1 7.5 5h1.6l1.15-1.5h3.5L14.9 5h1.6a2.75 2.75 0 0 1 2.75 2.75v8.5A2.75 2.75 0 0 1 16.5 19H7.5a2.75 2.75 0 0 1-2.75-2.75v-8.5Z"
      ></path>
      <path d="M12 15.5a3.25 3.25 0 1 0 0-6.5 3.25 3.25 0 0 0 0 6.5Z"></path>
    </symbol>
    <symbol id="nav-icon-map" viewBox="0 0 24 24">
      <path
        d="M9 18.75 4.75 20.5V6.25L9 4.5l6 1.75 4.25-1.75v14.25L15 20.5l-6-1.75Z"
      ></path>
      <path d="M9 4.5v14.25M15 6.25V20.5"></path>
      <path
        d="M12 8.75c1.1 0 2 .9 2 2 0 1.5-2 3.5-2 3.5s-2-2-2-3.5c0-1.1.9-2 2-2Z"
      ></path>
    </symbol>
  </svg>

  <div class="site-header__frame page-container">
    <nav class="site-nav" aria-label="Primary navigation">
      <a
        href={localizePath("/", locale)}
        class="site-brand"
        aria-label="Zoran Zhou home"
      >
        <span class="site-brand__mark" aria-hidden="true">
          <img
            src="/images/zoran-portrait.webp"
            alt=""
            width="512"
            height="512"
            decoding="async"
          />
        </span>
        <span class="site-brand__copy">
          <strong>ZORAN ZHOU</strong>
          <small>NETWORK / SECURITY</small>
        </span>
      </a>

      <div class="site-nav__links">
        {
          primaryNavItems.map((item) => {
            const active =
              path === item.href || path.startsWith(item.href + "/");
            return (
              <a
                href={item.href}
                class:list={["site-nav__link", { active }]}
                aria-current={active ? "page" : undefined}
              >
                {item.label}
              </a>
            );
          })
        }
      </div>

      <div class="site-nav__tools">
        <div class="site-nav__personal" aria-label="Personal sections">
          {
            personalNavItems.map((item) => {
              const active =
                path === item.href || path.startsWith(item.href + "/");
              return (
                <a
                  href={item.href}
                  class:list={["site-nav__icon", { active }]}
                  aria-label={item.label}
                  title={item.label}
                  aria-current={active ? "page" : undefined}
                >
                  <svg
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.7"
                  >
                    <use href={`#nav-icon-${item.icon}`} />
                  </svg>
                </a>
              );
            })
          }
        </div>

        <div class="site-search">
          <SearchModal client:load locale={locale} />
        </div>

        <a
          href={locale === "zh-CN" ? "/en/" : "/zh-CN/"}
          class="site-nav__language"
          aria-label={t.langLabel}
        >
          {localeLabels[locale === "zh-CN" ? "en" : "zh-CN"]}
        </a>

        <button
          id="theme-toggle"
          class="site-nav__control"
          aria-label="Toggle dark mode"
        >
          <svg
            class="hidden dark:block"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            viewBox="0 0 24 24"
          >
            <circle cx="12" cy="12" r="3.5"></circle>
            <path
              stroke-linecap="round"
              d="M12 2.5v2M12 19.5v2M21.5 12h-2M4.5 12h-2M18.7 5.3l-1.4 1.4M6.7 17.3l-1.4 1.4M18.7 18.7l-1.4-1.4M6.7 6.7 5.3 5.3"
            ></path>
          </svg>
          <svg
            class="block dark:hidden"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M20.2 15.5A8.8 8.8 0 0 1 8.5 3.8 8.8 8.8 0 1 0 20.2 15.5Z"
            ></path>
          </svg>
        </button>

        <button
          id="mobile-menu-toggle"
          class="site-nav__control site-nav__menu"
          aria-label="Toggle mobile menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg
            id="menu-icon-open"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            viewBox="0 0 24 24"
            ><path stroke-linecap="round" d="M5 8h14M5 16h14"></path></svg
          >
          <svg
            id="menu-icon-close"
            class="hidden"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            viewBox="0 0 24 24"
            ><path stroke-linecap="round" d="m7 7 10 10M17 7 7 17"></path></svg
          >
        </button>
      </div>
    </nav>
  </div>

  <div id="mobile-menu" class="site-mobile-menu" hidden>
    <div class="page-container site-mobile-menu__inner">
      <div class="site-mobile-menu__status"><span></span>SYSTEM NAVIGATION</div>
      <div class="site-mobile-menu__links">
        {
          primaryNavItems.map((item) => {
            const active =
              path === item.href || path.startsWith(item.href + "/");
            return (
              <a
                href={item.href}
                class:list={["site-mobile-menu__link", { active }]}
                aria-current={active ? "page" : undefined}
              >
                <>
                  <strong>{item.label}</strong>
                  <i>↗</i>
                </>
              </a>
            );
          })
        }
        {
          personalNavItems.map((item) => {
            const active =
              path === item.href || path.startsWith(item.href + "/");
            return (
              <a
                href={item.href}
                class:list={["site-mobile-menu__link", { active }]}
                aria-current={active ? "page" : undefined}
              >
                <>
                  <strong>{item.label}</strong>
                  <i>↗</i>
                </>
              </a>
            );
          })
        }
      </div>
      <div class="site-mobile-menu__languages">
        {
          locales.map((altLocale) => (
            <a
              href={altLocale === "zh-CN" ? "/zh-CN/" : "/en/"}
              class:list={{ active: altLocale === locale }}
            >
              {localeLabels[altLocale]}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</header>

<script>
  function toggleDarkMode() {
    const html = document.documentElement;
    const nextTheme = html.classList.contains("dark") ? "light" : "dark";
    html.classList.toggle("dark", nextTheme === "dark");
    localStorage.setItem("pref-theme", nextTheme);
  }

  document
    .getElementById("theme-toggle")
    ?.addEventListener("click", toggleDarkMode);

  const menuToggle = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIconOpen = document.getElementById("menu-icon-open");
  const menuIconClose = document.getElementById("menu-icon-close");

  function setMenu(open: boolean) {
    if (mobileMenu) mobileMenu.hidden = !open;
    menuToggle?.setAttribute("aria-expanded", String(open));
    menuIconOpen?.classList.toggle("hidden", open);
    menuIconClose?.classList.toggle("hidden", !open);
    document.body.classList.toggle("menu-open", open);
  }

  menuToggle?.addEventListener("click", () =>
    setMenu(mobileMenu?.hidden ?? true),
  );
  mobileMenu
    ?.querySelectorAll("a")
    .forEach((link) => link.addEventListener("click", () => setMenu(false)));
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMenu(false);
  });

  const siteHeader = document.querySelector<HTMLElement>("[data-site-header]");
  const updateHeaderState = () =>
    siteHeader?.classList.toggle("is-scrolled", window.scrollY > 12);
  window.addEventListener("scroll", updateHeaderState, { passive: true });
  updateHeaderState();
</script>

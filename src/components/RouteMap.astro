---
import type { RouteCoordinate } from "../lib/routes/content";

interface Props {
  title: string;
  gpx: string;
  displayGeometry?: string;
  coordinates?: RouteCoordinate;
  start?: RouteCoordinate;
  end?: RouteCoordinate;
  accent?: string;
  locale: "zh-CN" | "en";
}

const {
  title,
  gpx,
  displayGeometry,
  coordinates,
  start,
  end,
  accent = "#36d399",
  locale,
} = Astro.props;

const labels =
  locale === "zh-CN"
    ? {
        map: "路线地图",
        start: "起点",
        finish: "终点",
        elevation: "海拔变化",
        gain: "累计爬升",
        loss: "累计下降",
        range: "海拔范围",
        noElevation: "该轨迹暂时没有可用的海拔数据。",
        loadError: "路线文件加载失败，请检查 GPX 路径或文件内容。",
        routeProfile: "ROUTE PROFILE",
        splits: "每公里分段",
        kilometre: "公里",
        splitDistance: "分段距离",
        totalDuration: "总用时",
        pace: "配速",
        paceUnit: "分/公里",
        cadence: "步频",
        partial: "不足一公里",
      }
    : {
        map: "Route map",
        start: "Start",
        finish: "Finish",
        elevation: "Elevation profile",
        gain: "Elevation gain",
        loss: "Elevation loss",
        range: "Elevation range",
        noElevation: "Elevation data is not available for this route.",
        loadError:
          "The route file could not be loaded. Check the GPX path and file.",
        routeProfile: "ROUTE PROFILE",
        splits: "Per-kilometre splits",
        kilometre: "Kilometre",
        splitDistance: "Split distance",
        totalDuration: "Total time",
        pace: "Pace",
        paceUnit: "min/km",
        cadence: "Cadence",
        partial: "Partial",
      };

const mobileSplitLabels =
  locale === "zh-CN"
    ? { kilometre: "#", distance: "\u516c\u91cc", duration: "\u7528\u65f6" }
    : { kilometre: "#", distance: "Km", duration: "Time" };
---

<section
  class="route-visual"
  data-route-visual
  data-gpx={gpx}
  data-display-geometry={displayGeometry ?? ""}
  data-coordinates={coordinates ? JSON.stringify(coordinates) : ""}
  data-start={start ? JSON.stringify(start) : ""}
  data-end={end ? JSON.stringify(end) : ""}
  data-accent={accent}
  data-labels={JSON.stringify(labels)}
>
  <div class="route-map-card">
    <header class="route-map-card__header">
      <div>
        <span class="route-section-kicker">MAP</span>
        <h2>{labels.map}</h2>
      </div>
      <div class="route-map-legend" aria-hidden="true">
        <span><i class="route-dot route-dot--start"></i>{labels.start}</span>
        <span><i class="route-dot route-dot--finish"></i>{labels.finish}</span>
      </div>
    </header>

    <div class="route-map-shell">
      <div class="route-map" aria-label={`${title} · ${labels.map}`}></div>
      <p class="route-map-error" data-route-error hidden>{labels.loadError}</p>
    </div>
  </div>

  <section class="elevation-card" data-elevation-card hidden>
    <header class="elevation-card__header">
      <div>
        <span class="route-section-kicker">{labels.routeProfile}</span>
        <h2>{labels.elevation}</h2>
      </div>
      <dl class="elevation-card__stats">
        <div><dt>{labels.gain}</dt><dd data-elevation-gain>—</dd></div>
        <div><dt>{labels.loss}</dt><dd data-elevation-loss>—</dd></div>
        <div><dt>{labels.range}</dt><dd data-elevation-range>—</dd></div>
      </dl>
    </header>
    <div
      class="elevation-chart"
      data-elevation-chart
      role="img"
      aria-label={labels.elevation}
    >
    </div>
  </section>
  <p class="elevation-empty" data-elevation-empty hidden>
    {labels.noElevation}
  </p>

  <details class="route-splits" data-route-splits open hidden>
    <summary>{labels.splits}</summary>

    <div class="route-splits__table-wrap">
      <table>
        <thead>
          <tr>
            <th>
              <span class="split-label--desktop">{labels.kilometre}</span>
              <span class="split-label--mobile">
                {mobileSplitLabels.kilometre}
              </span>
            </th>
            <th>
              <span class="split-label--desktop">{labels.splitDistance}</span>
              <span class="split-label--mobile">
                {mobileSplitLabels.distance}
              </span>
            </th>
            <th>
              <span class="split-label--desktop">{labels.totalDuration}</span>
              <span class="split-label--mobile">
                {mobileSplitLabels.duration}
              </span>
            </th>
            <th>{labels.pace}</th>
            <th data-cadence-heading>{labels.cadence}</th>
          </tr>
        </thead>

        <tbody data-route-splits-body></tbody>
      </table>
    </div>
  </details>
</section>

<script>
  import maplibregl, { LngLatBounds, type Marker } from "maplibre-gl";
  import {
    parseRouteDocument,
    type ParsedRoute,
    type RoutePoint,
  } from "../lib/routes/gpx";
  import { processRouteForDisplay } from "../lib/routes/display-geometry";
  import { resolveRouteEndpoints } from "../lib/routes/endpoints";
  import {
    calculateKilometreSplits,
    formatPace,
    formatSplitDuration,
  } from "../lib/routes/splits";

  type Coordinate = { lat: number; lng: number; name?: string };

  const root = document.querySelector<HTMLElement>("[data-route-visual]");

  function parseJson<T>(value: string | undefined, fallback: T): T {
    if (!value) return fallback;
    try {
      return JSON.parse(value) as T;
    } catch {
      return fallback;
    }
  }

  function endpointElement(kind: "start" | "finish", label: string) {
    const element = document.createElement("div");
    element.className = `route-endpoint route-endpoint--${kind}`;
    element.setAttribute("aria-label", label);
    element.textContent = kind === "start" ? "S" : "F";
    return element;
  }

  function renderElevation(routeData: ParsedRoute, accent: string) {
    const points = routeData.points;
    if (!root) return;
    const card = root.querySelector<HTMLElement>("[data-elevation-card]");
    const empty = root.querySelector<HTMLElement>("[data-elevation-empty]");
    const chart = root.querySelector<HTMLElement>("[data-elevation-chart]");
    const samples = points.filter(
      (point) =>
        Number.isFinite(point.elevation) && Number.isFinite(point.distance),
    );

    if (!card || !empty || !chart || samples.length < 2) {
      if (empty) empty.hidden = false;
      return;
    }

    const elevations = samples.map((point) => point.elevation!);
    const maxChartPoints = 800;
    const chartSamples =
      samples.length <= maxChartPoints
        ? samples
        : Array.from({ length: maxChartPoints }, (_, index) => {
            const sourceIndex = Math.round(
              (index / (maxChartPoints - 1)) * (samples.length - 1),
            );
            return samples[sourceIndex];
          });
    const gain = routeData.elevationGainMeters ?? 0;
    const loss = routeData.elevationLossMeters ?? 0;
    const minimum = routeData.minElevationMeters ?? Math.min(...elevations);
    const maximum = routeData.maxElevationMeters ?? Math.max(...elevations);
    const totalDistance = samples.at(-1)?.distance ?? 0;
    const width = 900;
    const height = 260;
    const padding = { top: 22, right: 18, bottom: 38, left: 54 };
    const plotWidth = width - padding.left - padding.right;
    const plotHeight = height - padding.top - padding.bottom;
    const elevationRange = Math.max(1, maximum - minimum);
    const x = (point: RoutePoint) =>
      padding.left +
      ((point.distance ?? 0) / Math.max(1, totalDistance)) * plotWidth;
    const y = (point: RoutePoint) =>
      padding.top +
      (1 - (point.elevation! - minimum) / elevationRange) * plotHeight;
    const line = chartSamples
      .map(
        (point, index) =>
          `${index === 0 ? "M" : "L"}${x(point).toFixed(1)},${y(point).toFixed(1)}`,
      )
      .join(" ");
    const area = `${line} L${x(chartSamples.at(-1)!).toFixed(1)},${padding.top + plotHeight} L${x(chartSamples[0]).toFixed(1)},${padding.top + plotHeight} Z`;
    const distanceKm = totalDistance / 1_000;

    chart.innerHTML = `<svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" aria-hidden="true">
      <defs><linearGradient id="route-elevation-fill" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="${accent}" stop-opacity=".32"/><stop offset="1" stop-color="${accent}" stop-opacity=".03"/></linearGradient></defs>
      <line class="elevation-grid" x1="${padding.left}" y1="${padding.top}" x2="${padding.left + plotWidth}" y2="${padding.top}"/>
      <line class="elevation-grid" x1="${padding.left}" y1="${padding.top + plotHeight / 2}" x2="${padding.left + plotWidth}" y2="${padding.top + plotHeight / 2}"/>
      <line class="elevation-grid" x1="${padding.left}" y1="${padding.top + plotHeight}" x2="${padding.left + plotWidth}" y2="${padding.top + plotHeight}"/>
      <path d="${area}" fill="url(#route-elevation-fill)"/>
      <path d="${line}" fill="none" stroke="${accent}" stroke-width="3" vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round"/>
      <text class="elevation-axis" x="${padding.left - 8}" y="${padding.top + 4}" text-anchor="end">${Math.round(maximum)} m</text>
      <text class="elevation-axis" x="${padding.left - 8}" y="${padding.top + plotHeight + 4}" text-anchor="end">${Math.round(minimum)} m</text>
      <text class="elevation-axis" x="${padding.left}" y="${height - 10}" text-anchor="start">0 km</text>
      <text class="elevation-axis" x="${padding.left + plotWidth}" y="${height - 10}" text-anchor="end">${distanceKm.toFixed(1)} km</text>
    </svg>`;

    const gainElement = root.querySelector<HTMLElement>(
      "[data-elevation-gain]",
    );
    const lossElement = root.querySelector<HTMLElement>(
      "[data-elevation-loss]",
    );
    const rangeElement = root.querySelector<HTMLElement>(
      "[data-elevation-range]",
    );
    if (gainElement) gainElement.textContent = `${Math.round(gain)} m`;
    if (lossElement) lossElement.textContent = `${Math.round(loss)} m`;
    if (rangeElement) {
      rangeElement.textContent = `${Math.round(minimum)}–${Math.round(maximum)} m`;
    }
    card.hidden = false;
    empty.hidden = true;
  }

  function renderSplits(
    routeData: ParsedRoute,
    labels: Record<string, string>,
  ) {
    if (!root) return;

    const section = root.querySelector<HTMLDetailsElement>(
      "[data-route-splits]",
    );

    const body = root.querySelector<HTMLTableSectionElement>(
      "[data-route-splits-body]",
    );

    const cadenceHeading = root.querySelector<HTMLElement>(
      "[data-cadence-heading]",
    );

    if (!section || !body || !cadenceHeading) return;

    const splits = calculateKilometreSplits(routeData);

    if (splits.length === 0) return;

    const hasCadence = splits.some((split) => split.averageCadence != null);

    const fastestPace = Math.min(
      ...splits.map((split) => split.paceSecondsPerKm),
    );

    cadenceHeading.hidden = !hasCadence;
    section.dataset.hasCadence = String(hasCadence);

    let totalDurationSeconds = 0;

    body.replaceChildren(
      ...splits.map((split) => {
        totalDurationSeconds += split.durationSeconds;

        const row = document.createElement("tr");
        row.classList.toggle(
          "is-fastest",
          Math.abs(split.paceSecondsPerKm - fastestPace) < 0.01,
        );

        const desktopValues = [
          `${split.kilometre}${split.partial ? ` (${labels.partial})` : ""}`,
          `${(split.distanceMeters / 1_000).toFixed(split.partial ? 2 : 1)} km`,
          formatSplitDuration(totalDurationSeconds),
          `${formatPace(split.paceSecondsPerKm)} ${labels.paceUnit}`,
          split.averageCadence == null
            ? "—"
            : `${Math.round(split.averageCadence)} spm`,
        ];

        const mobileValues = [
          `${split.kilometre}${split.partial ? "*" : ""}`,
          (split.distanceMeters / 1_000).toFixed(split.partial ? 2 : 1),
          formatSplitDuration(split.durationSeconds),
          `${formatPace(split.paceSecondsPerKm).replace(":", "'")}"`,
          split.averageCadence == null
            ? "-"
            : String(Math.round(split.averageCadence)),
        ];

        desktopValues.forEach((value, index) => {
          const cell = document.createElement("td");
          const desktopValue = document.createElement("span");
          const mobileValue = document.createElement("span");

          desktopValue.className = "split-value--desktop";
          desktopValue.textContent = value;
          mobileValue.className = "split-value--mobile";
          mobileValue.textContent = mobileValues[index] ?? value;
          cell.append(desktopValue, mobileValue);

          if (index === 4) {
            cell.hidden = !hasCadence;
          }

          row.append(cell);
        });

        return row;
      }),
    );

    section.hidden = false;
  }

  if (root) {
    const gpx = root.dataset.gpx;
    const displayGeometry = root.dataset.displayGeometry;
    const coordinates = parseJson<Coordinate | undefined>(
      root.dataset.coordinates,
      undefined,
    );
    const frontmatterStart = parseJson<Coordinate | undefined>(
      root.dataset.start,
      undefined,
    );
    const frontmatterEnd = parseJson<Coordinate | undefined>(
      root.dataset.end,
      undefined,
    );
    const labels = parseJson<Record<string, string>>(root.dataset.labels, {});
    const accent = root.dataset.accent ?? "#36d399";
    const mapContainer = root.querySelector<HTMLElement>(".route-map");
    const errorElement = root.querySelector<HTMLElement>("[data-route-error]");
    const lightStyle =
      "https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json";
    const darkStyle =
      "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json";
    const initial = coordinates ?? frontmatterStart;
    let parsedRoute: ParsedRoute | undefined;
    let displaySegments: RoutePoint[][] = [];
    let markers: Marker[] = [];

    const map = new maplibregl.Map({
      container: mapContainer!,
      style: document.documentElement.classList.contains("dark")
        ? darkStyle
        : lightStyle,
      center: initial ? [initial.lng, initial.lat] : [114.1694, 22.3193],
      zoom: initial ? 13 : 2.5,
      attributionControl: false,
    });
    map.addControl(
      new maplibregl.NavigationControl({ showCompass: false }),
      "bottom-right",
    );
    map.addControl(
      new maplibregl.AttributionControl({ compact: true }),
      "bottom-right",
    );

    function clearMapData() {
      for (const id of ["route-line", "route-glow"]) {
        if (map.getLayer(id)) map.removeLayer(id);
      }
      if (map.getSource("route")) map.removeSource("route");
      markers.forEach((marker) => marker.remove());
      markers = [];
    }

    function drawParsedRoute(routeData: ParsedRoute) {
      clearMapData();
      const points = routeData.points;
      const { start, end } = resolveRouteEndpoints(
        frontmatterStart,
        frontmatterEnd,
        routeData.segments,
      );

      if (displaySegments.length > 0) {
        const geometry =
          displaySegments.length === 1
            ? {
                type: "LineString" as const,
                coordinates: displaySegments[0].map((point) => [
                  point.lng,
                  point.lat,
                ]),
              }
            : {
                type: "MultiLineString" as const,
                coordinates: displaySegments.map((segment) =>
                  segment.map((point) => [point.lng, point.lat]),
                ),
              };
        map.addSource("route", {
          type: "geojson",
          data: {
            type: "Feature",
            properties: {},
            geometry,
          },
        });
        map.addLayer({
          id: "route-glow",
          type: "line",
          source: "route",
          paint: {
            "line-color": accent,
            "line-width": 11,
            "line-opacity": 0.14,
            "line-blur": 5,
          },
        });
        map.addLayer({
          id: "route-line",
          type: "line",
          source: "route",
          paint: {
            "line-color": accent,
            "line-width": 4,
            "line-opacity": 0.94,
          },
        });
      }

      if (start) {
        markers.push(
          new maplibregl.Marker({
            element: endpointElement("start", labels.start ?? "Start"),
            anchor: "center",
          })
            .setLngLat([start.lng, start.lat])
            .addTo(map),
        );
      }
      if (end) {
        markers.push(
          new maplibregl.Marker({
            element: endpointElement("finish", labels.finish ?? "Finish"),
            anchor: "center",
          })
            .setLngLat([end.lng, end.lat])
            .addTo(map),
        );
      }

      const endpointNames = new Set([start?.name, end?.name].filter(Boolean));
      routeData.waypoints
        .filter((waypoint) => !endpointNames.has(waypoint.name))
        .slice(0, 30)
        .forEach((waypoint, index) => {
          const element = document.createElement("div");
          element.className = "route-waypoint";
          element.textContent = String(index + 1);
          element.setAttribute(
            "aria-label",
            waypoint.name ?? `Waypoint ${index + 1}`,
          );
          const marker = new maplibregl.Marker({
            element,
            anchor: "center",
          }).setLngLat([waypoint.lng, waypoint.lat]);
          if (waypoint.name) {
            marker.setPopup(
              new maplibregl.Popup({ offset: 18 }).setText(waypoint.name),
            );
          }
          markers.push(marker.addTo(map));
        });

      if (points.length > 0) {
        const bounds = new LngLatBounds();
        points.forEach((point) => bounds.extend([point.lng, point.lat]));
        map.fitBounds(bounds, {
          padding: { top: 55, right: 55, bottom: 55, left: 55 },
          maxZoom: 15,
          duration: 800,
        });
      }
      renderElevation(routeData, accent);
      renderSplits(routeData, labels);
    }

    async function loadRoute() {
      if (parsedRoute) return parsedRoute;
      if (gpx) {
        const response = await fetch(gpx);
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        parsedRoute = parseRouteDocument(await response.text(), gpx);
        displaySegments = processRouteForDisplay(parsedRoute.segments);

        if (displayGeometry) {
          try {
            const displayResponse = await fetch(displayGeometry);
            if (displayResponse.ok) {
              const cachedGeometry = parseRouteDocument(
                await displayResponse.text(),
                displayGeometry,
              );
              if (cachedGeometry.points.length > 1) {
                displaySegments = processRouteForDisplay(
                  cachedGeometry.segments,
                );
              }
            }
          } catch {}
        }
      }
      return parsedRoute;
    }

    const routePromise = loadRoute();
    routePromise
      .then((routeData) => {
        if (routeData) {
          renderElevation(routeData, accent);
          renderSplits(routeData, labels);
        }
      })
      .catch(() => {
        if (errorElement) errorElement.hidden = false;
      });

    map.on("load", async () => {
      try {
        const routeData = await routePromise;
        if (routeData && routeData.points.length > 0) {
          drawParsedRoute(routeData);
        } else if (initial) {
          markers.push(
            new maplibregl.Marker()
              .setLngLat([initial.lng, initial.lat])
              .addTo(map),
          );
        }
      } catch {
        if (errorElement) errorElement.hidden = false;
      }
    });
    map.on("error", () => {
      if (errorElement) errorElement.hidden = false;
    });

    const themeObserver = new MutationObserver(() => {
      map.setStyle(
        document.documentElement.classList.contains("dark")
          ? darkStyle
          : lightStyle,
      );
      map.once("style.load", () => {
        if (parsedRoute) drawParsedRoute(parsedRoute);
      });
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
    const resize = () => map.resize();
    window.addEventListener("resize", resize, { passive: true });
    window.addEventListener("orientationchange", resize, { passive: true });
    const cleanup = () => {
      themeObserver.disconnect();
      window.removeEventListener("resize", resize);
      window.removeEventListener("orientationchange", resize);
      markers.forEach((marker) => marker.remove());
      map.remove();
    };
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  }
</script>

<style>
  .route-visual {
    display: grid;
    gap: 1rem;
  }

  .route-map-card,
  .elevation-card,
  .route-splits {
    overflow: visible;
    overflow: hidden;
    border: 1px solid var(--border-color);
    border-radius: 1.25rem;
    background: var(--surface-color);
    box-shadow: 0 18px 55px rgb(15 23 42 / 0.08);
  }

  .route-map-card__header,
  .elevation-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: clamp(1rem, 3vw, 1.4rem);
  }

  .route-section-kicker {
    color: var(--text-muted);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  .route-map-card h2,
  .elevation-card h2 {
    margin: 0.25rem 0 0;
    font-size: clamp(1.1rem, 3vw, 1.45rem);
  }

  .route-map-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .route-map-legend span {
    display: inline-flex;
    align-items: center;
    gap: 0.38rem;
  }

  .route-dot {
    display: inline-block;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
  }

  .route-dot--start {
    background: #17a673;
  }

  .route-dot--finish {
    background: #ee4f67;
  }

  .route-map-shell {
    position: relative;
    border-block: 1px solid var(--border-color);
  }

  .route-map {
    width: 100%;
    height: clamp(420px, 58vw, 620px);
  }

  .route-map-error {
    position: absolute;
    inset: auto 1rem 1rem;
    margin: 0;
    padding: 0.8rem 1rem;
    border: 1px solid color-mix(in srgb, #ee4f67 40%, var(--border-color));
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--surface-color) 92%, #ee4f67);
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .elevation-card__stats dt {
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 700;
  }

  .elevation-card__stats dd {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 750;
  }

  :global(.route-endpoint) {
    display: grid;
    width: 2.2rem;
    height: 2.2rem;
    place-items: center;
    border: 3px solid #fff;
    border-radius: 50%;
    box-shadow: 0 6px 18px rgb(15 23 42 / 0.28);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 850;
  }

  :global(.route-endpoint--start) {
    background: #17a673;
  }

  :global(.route-endpoint--finish) {
    background: #ee4f67;
  }

  :global(.route-waypoint) {
    display: grid;
    width: 1.65rem;
    height: 1.65rem;
    place-items: center;
    border: 2px solid #fff;
    border-radius: 50%;
    background: #334155;
    box-shadow: 0 4px 12px rgb(15 23 42 / 0.25);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 800;
  }

  .elevation-card {
    padding-bottom: clamp(1rem, 3vw, 1.4rem);
  }

  .elevation-card__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.35rem;

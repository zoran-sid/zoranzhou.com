---
interface MapPoint {
  lat: number;
  lng: number;
  name?: string;
}

interface MapItem {
  slug: string;
  title: string;
  description?: string;

  date: string;
  dateLabel: string;

  kind: string;
  kindLabel: string;

  location: string;

  distance?: string;
  duration?: string;

  coordinates?: MapPoint;
  start?: MapPoint;
  end?: MapPoint;

  route: MapPoint[];
  segments: MapPoint[][];
  gpx?: string;
  displayGeometry?: string;

  mapZoom?: number;
  accent: string;
  url: string;
}

interface Props {
  items: MapItem[];

  locale: "zh-CN" | "en";

  labels: {
    all: string;
    explore: string;
    empty: string;
    details: string;
    distance: string;
    duration: string;
    mapped: string;
    start: string;
    end: string;
  };
}

const { items, locale, labels } = Astro.props;

const kinds = [...new Set(items.map((item) => item.kind))];

const mappedCount = items.filter(
  (item) => item.coordinates || item.start || item.end || item.gpx,
).length;

const pageUrl = Astro.url;

const initialSlug =
  pageUrl.searchParams.get("journey") ??
  items.find((item) => item.coordinates || item.start || item.end || item.gpx)
    ?.slug ??
  "";

const initialItem =
  items.find((item) => item.slug === initialSlug) ??
  items.find(
    (item) => item.coordinates || item.start || item.end || item.gpx,
  ) ??
  items[0];
---

<section
  class="journey-explorer"
  data-map-explorer
  data-items={JSON.stringify(items)}
  data-locale={locale}
  data-initial-slug={initialSlug}
  data-label-start={labels.start}
  data-label-end={labels.end}
>
  <header class="journey-toolbar">
    <div class="journey-toolbar__summary">
      <span class="journey-toolbar__eyebrow">
        {labels.explore}
      </span>

      <strong class="journey-toolbar__count">
        {mappedCount}
      </strong>

      <span class="journey-toolbar__count-label">
        {labels.mapped}
      </span>
    </div>

    <div class="journey-filters" role="group" aria-label={labels.explore}>
      <button
        type="button"
        class="journey-filter"
        data-active="true"
        data-map-filter="all"
      >
        {labels.all}
      </button>

      {
        kinds.map((kind) => {
          const item = items.find((entry) => entry.kind === kind);

          return (
            <button type="button" class="journey-filter" data-map-filter={kind}>
              {item?.kindLabel ?? kind}
            </button>
          );
        })
      }
    </div>
  </header>

  <div class="journey-workspace">
    <aside class="journey-sidebar" aria-label={labels.explore}>
      <div class="journey-sidebar__heading">
        <span>{labels.explore}</span>

        <span class="journey-sidebar__count">
          {String(items.length).padStart(2, "0")}
        </span>
      </div>

      <div class="journey-list">
        {
          items.map((item, index) => (
            <button
              type="button"
              class:list={[
                "journey-card",
                {
                  active: item.slug === initialItem?.slug,
                },
              ]}
              data-map-item={item.slug}
              data-map-kind={item.kind}
              disabled={
                !item.coordinates && !item.start && !item.end && !item.gpx
              }
              aria-pressed={item.slug === initialItem?.slug}
            >
              <span class="journey-card__index">
                {String(index + 1).padStart(2, "0")}
              </span>

              <span class="journey-card__content">
                <strong class="journey-card__title">{item.title}</strong>

                <span class="journey-card__meta">
                  {item.location}

                  <span aria-hidden="true">{" · "}</span>

                  {item.dateLabel}
                </span>
              </span>
            </button>
          ))
        }
      </div>
    </aside>

    <section class="journey-detail" aria-live="polite">
      <header class="journey-detail__header">
        <div class="journey-detail__text">
          <div class="journey-detail__meta">
            <span class="journey-detail__kind" data-map-detail-kind>
              {initialItem?.kindLabel.toUpperCase() ?? ""}
            </span>

            <time
              class="journey-detail__date"
              data-map-detail-date
              datetime={initialItem?.date}
            >
              {initialItem?.dateLabel ?? ""}
            </time>
          </div>

          <h1 class="journey-detail__title" data-map-detail-title>
            {initialItem?.title ?? ""}
          </h1>

          <p class="journey-detail__summary" data-map-detail-description>
            {initialItem?.description ?? ""}
          </p>

          <dl class="journey-detail__stats">
            <div data-map-detail-distance-row hidden={!initialItem?.distance}>
              <dt>{labels.distance}</dt>

              <dd data-map-detail-distance>
                {initialItem?.distance ?? ""}
              </dd>
            </div>

            <div data-map-detail-duration-row hidden={!initialItem?.duration}>
              <dt>{labels.duration}</dt>

              <dd data-map-detail-duration>
                {initialItem?.duration ?? ""}
              </dd>
            </div>
          </dl>
        </div>

        <a
          class="journey-detail__link"
          href={initialItem?.url ?? `/${locale}/map/`}
          data-map-detail-link
        >
          {labels.details}

          <span aria-hidden="true"> ↗ </span>
        </a>
      </header>

      <div class="journey-detail__map">
        <div class="journey-map-shell">
          <div class="journey-map-canvas" aria-label={labels.explore}></div>

          <div class="journey-endpoint-legend" aria-hidden="true">
            <span>
              <i class="journey-endpoint-legend__start"> S </i>

              {labels.start}
            </span>

            <span>
              <i class="journey-endpoint-legend__end"> F </i>

              {labels.end}
            </span>
          </div>

          <div
            class="journey-map-empty"
            data-map-empty-msg
            hidden={Boolean(
              initialItem?.gpx ||
              initialItem?.route.length ||
              initialItem?.start ||
              initialItem?.end,
            )}
          >
            {
              locale === "zh-CN"
                ? "该旅程暂时没有可用的路线数据。"
                : "Route data is not available for this journey."
            }
          </div>

          <div class="journey-map-empty" data-map-fallback-msg hidden>
            {
              locale === "zh-CN"
                ? "地图暂时无法加载，路线文字和详情链接仍可使用。"
                : "The map is unavailable. Route text and detail links remain available."
            }
          </div>
        </div>
      </div>
    </section>
  </div>

  {mappedCount === 0 && <div class="journey-empty-state">{labels.empty}</div>}
</section>

<script>
  import maplibregl, {
    LngLatBounds,
    type Map as MapLibreMap,
    type Marker,
  } from "maplibre-gl";

  import { parseRouteDocument } from "../lib/routes/gpx";

  import { processRouteForDisplay } from "../lib/routes/display-geometry";

  type Point = {
    lat: number;
    lng: number;
    name?: string;
  };

  type Journey = {
    slug: string;
    title: string;
    description?: string;

    date: string;
    dateLabel: string;

    kind: string;
    kindLabel: string;

    location: string;

    distance?: string;
    duration?: string;

    coordinates?: Point;
    start?: Point;
    end?: Point;

    route: Point[];
    segments: Point[][];
    gpx?: string;
    displayGeometry?: string;

    accent: string;
    url: string;
    mapZoom?: number;
  };

  type LoadedRoute = {
    points: Point[];
    segments: Point[][];
    start?: Point;
    end?: Point;
  };

  let activeRoot: HTMLElement | null = null;
  let cleanupActiveExplorer = () => {};

  function initializeMapExplorer() {
    const root = document.querySelector<HTMLElement>("[data-map-explorer]")!;
    if (root === activeRoot) return;
    cleanupActiveExplorer();
    activeRoot = root;
    if (!root) return;

    const items: Journey[] = JSON.parse(root.dataset.items ?? "[]");

    const initialSlug = root.dataset.initialSlug ?? "";

    const startLabel = root.dataset.labelStart ?? "Start";

    const endLabel = root.dataset.labelEnd ?? "End";

    const isDark = document.documentElement.classList.contains("dark");

    const lightStyle =
      "https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json";

    const darkStyle =
      "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json";

    let map: MapLibreMap | null = null;

    let selectedSlug: string | null = null;

    let currentRouteSourceId: string | null = null;

    let disconnectThemeObserver = () => {};

    const markers = new Map<string, Marker>();

    const endpointMarkers: Marker[] = [];

    const routeCache = new Map<string, LoadedRoute>();

    function copyPoint(point: Point | undefined): Point | undefined {
      if (
        !point ||
        !Number.isFinite(point.lat) ||
        !Number.isFinite(point.lng)
      ) {
        return undefined;
      }

      return {
        lat: point.lat,
        lng: point.lng,
        name: point.name,
      };
    }

    function parseLoadedRoute(text: string, gpx: string): LoadedRoute {
      const parsed = parseRouteDocument(text, gpx);

      const segments = processRouteForDisplay(parsed.segments).map((segment) =>
        segment.map(({ lat, lng }) => ({ lat, lng })),
      );
      const points = segments.flat();

      const start = copyPoint(parsed.start) ?? copyPoint(points[0]);

      const end = copyPoint(parsed.end) ?? copyPoint(points.at(-1));

      return {
        points,
        segments,
        start,
        end,
      };
    }

    async function ensureRouteLoaded(item: Journey): Promise<LoadedRoute> {
      const existingStart = copyPoint(item.start) ?? copyPoint(item.route[0]);

      const existingEnd = copyPoint(item.end) ?? copyPoint(item.route.at(-1));

      if (item.route.length > 1) {
        return {
          points: item.route,
          segments: item.segments.length > 0 ? item.segments : [item.route],
          start: existingStart,
          end: existingEnd,
        };
      }

      const cacheKey = item.gpx ?? item.slug;

      const cached = routeCache.get(cacheKey);

      if (cached) {
        item.route = cached.points;
        item.segments = cached.segments;

        item.start ??= cached.start;

        item.end ??= cached.end;

        return cached;
      }

      if (!item.gpx) {
        return {
          points: item.route,
          segments: item.segments,
          start: existingStart,
          end: existingEnd,
        };
      }

      try {
        const response = await fetch(item.gpx);

        if (!response.ok) {
          return {
            points: [],
            segments: [],
            start: existingStart,
            end: existingEnd,
          };
        }

        const text = await response.text();

        let loaded = parseLoadedRoute(text, item.gpx);

        // A cached matched GeoJSON is optional; raw GPX remains authoritative.
        if (item.displayGeometry) {
          try {
            const matchedResponse = await fetch(item.displayGeometry);
            if (matchedResponse.ok) {
              const matched = parseLoadedRoute(
                await matchedResponse.text(),
                item.displayGeometry,
              );
              if (matched.points.length > 1) {
                loaded = {
                  ...loaded,
                  points: matched.points,
                  segments: matched.segments,
                };
              }
            }
          } catch {}
        }

        if (loaded.points.length > 1) {
          item.route = loaded.points;
          item.segments = loaded.segments;
        }

        item.start ??= loaded.start;

        item.end ??= loaded.end;

        item.coordinates ??=
          loaded.start ?? loaded.points[Math.floor(loaded.points.length / 2)];

        routeCache.set(cacheKey, loaded);

        return loaded;
      } catch {
        return {
          points: [],
          segments: [],
          start: existingStart,
          end: existingEnd,
        };
      }
    }

    function removeCurrentRoute() {
      if (!map) {
        return;
      }

      if (currentRouteSourceId && map.getSource(currentRouteSourceId)) {
        try {
          if (map.getLayer("route-glow")) {
            map.removeLayer("route-glow");
          }
        } catch {}

        try {
          if (map.getLayer("route-line")) {
            map.removeLayer("route-line");
          }
        } catch {}

        try {
          map.removeSource(currentRouteSourceId);
        } catch {}
      }

      currentRouteSourceId = null;
    }

    function clearEndpointMarkers() {
      while (endpointMarkers.length) {
        endpointMarkers.pop()?.remove();
      }
    }

    function endpointElement(kind: "start" | "end", label: string) {
      const element = document.createElement("div");

      element.className = `journey-endpoint-marker journey-endpoint-marker--${kind}`;

      element.setAttribute("aria-label", label);

      const badge = document.createElement("strong");

      badge.textContent = kind === "start" ? "S" : "F";

      const caption = document.createElement("span");

      caption.textContent = label;

      element.append(badge, caption);

      return element;
    }

    function addEndpointMarkers(item: Journey) {
      if (!map) {
        return 0;
      }

      clearEndpointMarkers();

      const start = copyPoint(item.start) ?? copyPoint(item.route[0]);

      const end = copyPoint(item.end) ?? copyPoint(item.route.at(-1));

      if (!start && !end) {
        return 0;
      }

      if (start) {
        endpointMarkers.push(
          new maplibregl.Marker({
            element: endpointElement("start", startLabel),

            anchor: "center",
          })
            .setLngLat([start.lng, start.lat])
            .addTo(map),
        );
      }

      if (end) {
        endpointMarkers.push(
          new maplibregl.Marker({
            element: endpointElement("end", endLabel),

            anchor: "center",
          })
            .setLngLat([end.lng, end.lat])
            .addTo(map),
        );
      }

      return endpointMarkers.length;
    }

    function updateOverviewMarkerState(hideOverviewMarkers: boolean) {
      markers.forEach((marker) => {
        const element = marker.getElement();
        element.classList.toggle("is-selected-route", hideOverviewMarkers);
        element.hidden = hideOverviewMarkers;
      });
    }

    function addRouteToMap(item: Journey) {
      if (!map || item.route.length < 2) {
        return;
      }

      removeCurrentRoute();

      const sourceId = `route-${item.slug}`;

      currentRouteSourceId = sourceId;

      if (map.getSource(sourceId)) {
        return;
      }

      map.addSource(sourceId, {
        type: "geojson",

        data: {
          type: "Feature",
          properties: {},

          geometry:
            item.segments.length > 1
              ? {
                  type: "MultiLineString",
                  coordinates: item.segments.map((segment) =>
                    segment.map((point) => [point.lng, point.lat]),
                  ),
                }
              : {
                  type: "LineString",
                  coordinates: (item.segments[0] ?? item.route).map((point) => [
                    point.lng,
                    point.lat,
                  ]),
                },
        },
      });

      map.addLayer({
        id: "route-glow",
        type: "line",
        source: sourceId,

        paint: {
          "line-color": item.accent,

          "line-width": 10,

          "line-opacity": 0.13,

          "line-blur": 5,
        },
      });

      map.addLayer({
        id: "route-line",
        type: "line",
        source: sourceId,

        paint: {
          "line-color": item.accent,

          "line-width": 3.5,

          "line-opacity": 0.9,
        },
      });
    }

    function fitRouteToMap(item: Journey, animate = true) {
      if (!map) {
        return;
      }

      if (item.route.length > 1) {
        const bounds = new LngLatBounds();

        item.route.forEach((point) => {
          bounds.extend([point.lng, point.lat]);
        });

        const compact = map.getContainer().clientWidth < 640;

        map.fitBounds(bounds, {
          padding: compact
            ? {
                top: 46,
                right: 46,
                bottom: 46,
                left: 46,
              }
            : {
                top: 70,
                right: 70,
                bottom: 70,
                left: 70,
              },

          maxZoom: 15,

          duration: animate ? 800 : 0,
        });

        return;
      }

      const focus = item.start ?? item.end ?? item.coordinates;

      if (focus) {
        map.flyTo({
          center: [focus.lng, focus.lat],

          zoom: item.mapZoom ?? 13,

          duration: animate ? 800 : 0,
        });
      }
    }

    function updateDetailUI(item: Journey) {
      const select = (selector: string) =>
        root.querySelector<HTMLElement>(selector)!;

      select("[data-map-detail-kind]").textContent =
        item.kindLabel.toUpperCase();

      const dateElement = select("[data-map-detail-date]") as HTMLTimeElement;

      dateElement.textContent = item.dateLabel;

      dateElement.setAttribute("datetime", item.date);

      select("[data-map-detail-title]").textContent = item.title;

      select("[data-map-detail-description]").textContent =
        item.description ?? "";

      const distanceRow = select("[data-map-detail-distance-row]");

      const durationRow = select("[data-map-detail-duration-row]");

      distanceRow.hidden = !item.distance;

      durationRow.hidden = !item.duration;

      select("[data-map-detail-distance]").textContent = item.distance ?? "";

      select("[data-map-detail-duration]").textContent = item.duration ?? "";

      (select("[data-map-detail-link]") as HTMLAnchorElement).href = item.url;

      select("[data-map-empty-msg]").hidden =
        item.route.length > 1 || Boolean(item.gpx || item.start || item.end);

      root
        .querySelectorAll<HTMLButtonElement>("[data-map-item]")
        .forEach((button) => {
          const active = button.dataset.mapItem === item.slug;

          button.classList.toggle("active", active);

          button.setAttribute("aria-pressed", String(active));
        });
    }

    async function showJourney(item: Journey) {
      selectedSlug = item.slug;

      updateDetailUI(item);

      const url = new URL(window.location.href);

      url.searchParams.set("journey", item.slug);

      window.history.replaceState(
        {
          journey: item.slug,
        },
        "",
        url,
      );

      clearEndpointMarkers();

      updateOverviewMarkerState(false);

      removeCurrentRoute();

      const loaded = await ensureRouteLoaded(item);

      if (selectedSlug !== item.slug) return;

      if (loaded.points.length > 1) {
        item.route = loaded.points;
        item.segments = loaded.segments;
      }

      item.start ??= loaded.start;

      item.end ??= loaded.end;

      if (item.route.length <= 1 && !item.start && !item.end) {
        root.querySelector<HTMLElement>("[data-map-empty-msg]")!.hidden = false;

        return;
      }

      root.querySelector<HTMLElement>("[data-map-empty-msg]")!.hidden = true;

      addRouteToMap(item);

      const endpointCount = addEndpointMarkers(item);

      updateOverviewMarkerState(endpointCount > 0);

      fitRouteToMap(item, true);
    }

    function applyFilter(kind: string) {
      root
        .querySelectorAll<HTMLButtonElement>("[data-map-filter]")
        .forEach((button) => {
          button.setAttribute(
            "data-active",
            String(button.dataset.mapFilter === kind),
          );
        });

      root
        .querySelectorAll<HTMLButtonElement>("[data-map-item]")
        .forEach((button) => {
          button.hidden = kind !== "all" && button.dataset.mapKind !== kind;
        });

      if (selectedSlug) {
        const selected = items.find((item) => item.slug === selectedSlug);

        if (selected && kind !== "all" && selected.kind !== kind) {
          const first = items.find(
            (item) =>
              (kind === "all" || item.kind === kind) &&
              (item.coordinates || item.start || item.end || item.gpx),
          );

          if (first) {
            void showJourney(first);
          } else {
            clearEndpointMarkers();
            removeCurrentRoute();

            updateOverviewMarkerState(false);
          }
        }
      }

      items.forEach((item) => {
        const visible = kind === "all" || item.kind === kind;

        const marker = markers.get(item.slug);

        if (marker) {
          marker.getElement().classList.toggle("filtered", !visible);
        }

        if (!visible && currentRouteSourceId === `route-${item.slug}`) {
          removeCurrentRoute();
        }
      });
    }

    const initialJourney =
      items.find((item) => item.slug === initialSlug) ??
      items.find(
        (item) => item.coordinates || item.start || item.end || item.gpx,
      ) ??
      items[0];

    if (initialJourney) {
      selectedSlug = initialJourney.slug;

      updateDetailUI(initialJourney);
    }

    try {
      const mapContainer = root.querySelector<HTMLElement>(
        ".journey-map-canvas",
      );

      if (!mapContainer) {
        throw new Error("Map container not found");
      }

      map = new maplibregl.Map({
        container: mapContainer,

        style: isDark ? darkStyle : lightStyle,

        center: [120.15, 30.25],

        zoom: 12,
        minZoom: 1.6,
        maxZoom: 16,

        attributionControl: false,
      });

      map.addControl(
        new maplibregl.NavigationControl({
          showCompass: false,
        }),
        "bottom-right",
      );

      map.addControl(
        new maplibregl.AttributionControl({
          compact: true,
        }),
        "bottom-right",
      );
    } catch {
      root.classList.add("map-fallback");

      root.querySelector<HTMLElement>("[data-map-fallback-msg]")!.hidden =
        false;
    }

    if (map) {
      let mapLoaded = false;

      const mapLoadTimeout = window.setTimeout(() => {
        if (!mapLoaded) {
          root.classList.add("map-fallback");

          root.querySelector<HTMLElement>("[data-map-fallback-msg]")!.hidden =
            false;
        }
      }, 10_000);

      map.on("load", async () => {
        mapLoaded = true;

        window.clearTimeout(mapLoadTimeout);

        root.classList.remove("map-fallback");

        root.querySelector<HTMLElement>("[data-map-fallback-msg]")!.hidden =
          true;

        items
          .filter((item) => item.coordinates || item.start || item.end)
          .forEach((item) => {
            const coordinates = item.coordinates ?? item.start ?? item.end;

            if (!coordinates) {
              return;
            }

            const element = document.createElement("button");

            element.type = "button";

            element.className = "journey-marker";

            element.dataset.kind = item.kind;

            element.setAttribute("aria-label", item.title);

            element.style.setProperty("--marker-accent", item.accent);

            element.innerHTML = "<span></span>";

            element.addEventListener("click", () => {
              void showJourney(item);
            });

            markers.set(
              item.slug,

              new maplibregl.Marker({
                element,
              })
                .setLngLat([coordinates.lng, coordinates.lat])
                .addTo(map!),
            );
          });

        if (initialJourney) {
          await showJourney(initialJourney);
        }
      });

      map.on("error", () => {
        if (!mapLoaded) {
          root.classList.add("map-fallback");

          root.querySelector<HTMLElement>("[data-map-fallback-msg]")!.hidden =
            false;
        }
      });

      const themeObserver = new MutationObserver(() => {
        const nextDark = document.documentElement.classList.contains("dark");

        map!.setStyle(nextDark ? darkStyle : lightStyle);

        map!.once("style.load", () => {
          const selected = items.find((item) => item.slug === selectedSlug);

          if (selected) {
            addRouteToMap(selected);
            const endpointCount = addEndpointMarkers(selected);
            updateOverviewMarkerState(endpointCount > 0);
          }
        });
      });

      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });

      disconnectThemeObserver = () => themeObserver.disconnect();
    }

    root
      .querySelectorAll<HTMLButtonElement>("[data-map-item]")
      .forEach((button) => {
        button.addEventListener("click", () => {
          const item = items.find(
            (entry) => entry.slug === button.dataset.mapItem,
          );

          if (
            item &&
            (item.coordinates || item.start || item.end || item.gpx)
          ) {
            void showJourney(item);
          }
        });
      });

    root
      .querySelectorAll<HTMLButtonElement>("[data-map-filter]")
      .forEach((button) => {
        button.addEventListener("click", () => {
          applyFilter(button.dataset.mapFilter ?? "all");
        });
      });

    const handlePopState = () => {
      const parameters = new URLSearchParams(window.location.search);

      const slug = parameters.get("journey");

      const item = slug ? items.find((entry) => entry.slug === slug) : null;

      if (item && (item.coordinates || item.start || item.end || item.gpx)) {
        void showJourney(item);
      }
    };

    window.addEventListener("popstate", handlePopState);

    const resizeMap = () => {
      map?.resize();

      const selected = items.find((item) => item.slug === selectedSlug);

      if (selected) {
        fitRouteToMap(selected, false);
      }
    };

    window.addEventListener("resize", resizeMap, {
      passive: true,
    });

    window.addEventListener("orientationchange", resizeMap, {
      passive: true,
    });

    cleanupActiveExplorer = () => {
      window.removeEventListener("resize", resizeMap);

      window.removeEventListener("orientationchange", resizeMap);

      window.removeEventListener("popstate", handlePopState);

      disconnectThemeObserver();

      clearEndpointMarkers();

      markers.forEach((marker) => marker.remove());

      markers.clear();

      map?.remove();

      map = null;
      activeRoot = null;
      cleanupActiveExplorer = () => {};
    };
  }

  initializeMapExplorer();
  document.addEventListener("astro:page-load", initializeMapExplorer);
  document.addEventListener("astro:before-swap", () => cleanupActiveExplorer());
</script>

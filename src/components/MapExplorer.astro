---
interface MapPoint {
  lat: number;
  lng: number;
}

interface MapItem {
  slug: string;
  title: string;
  description?: string;
  date: string;
  dateLabel: string;
  kind: string;
  kindLabel: string;
  location: string;
  distance?: string;
  duration?: string;
  coordinates?: MapPoint;
  route: MapPoint[];
  gpx?: string;
  mapZoom?: number;
  accent: string;
  url: string;
}

interface Props {
  items: MapItem[];
  locale: "zh-CN" | "en";
  labels: {
    all: string;
    explore: string;
    empty: string;
    details: string;
    distance: string;
    duration: string;
    mapped: string;
  };
}

const { items, locale, labels } = Astro.props;
const kinds = [...new Set(items.map((item) => item.kind))];
const mappedCount = items.filter(
  (item) => item.coordinates || item.gpx,
).length;

const pageUrl = Astro.url;
const initialSlug =
  pageUrl.searchParams.get("journey") ??
  items.find((item) => item.coordinates || item.gpx)?.slug ??
  "";
const initialItem =
  items.find((item) => item.slug === initialSlug) ??
  items.find((item) => item.coordinates || item.gpx) ??
  items[0];
---

<section
  class="journey-explorer"
  data-map-explorer
  data-items={JSON.stringify(items)}
  data-locale={locale}
  data-initial-slug={initialSlug}
>
  <!-- ====== Toolbar ====== -->
  <header class="journey-toolbar">
    <div class="journey-toolbar__summary">
      <span class="journey-toolbar__eyebrow">{labels.explore}</span>
      <strong class="journey-toolbar__count">{mappedCount}</strong>
      <span class="journey-toolbar__count-label">{labels.mapped}</span>
    </div>
    <div class="journey-filters" role="group" aria-label={labels.explore}>
      <button
        type="button"
        class="journey-filter"
        data-active="true"
        data-map-filter="all"
      >
        {labels.all}
      </button>
      {
        kinds.map((kind) => {
          const item = items.find((entry) => entry.kind === kind);
          return (
            <button type="button" class="journey-filter" data-map-filter={kind}>
              {item?.kindLabel ?? kind}
            </button>
          );
        })
      }
    </div>
  </header>

  <!-- ====== Workspace: Grid sidebar + detail ====== -->
  <div class="journey-workspace">
    <!-- Left: Journey sidebar -->
    <aside class="journey-sidebar" aria-label={labels.explore}>
      <div class="journey-sidebar__heading">
        <span>{labels.explore}</span>
        <span class="journey-sidebar__count"
          >{String(items.length).padStart(2, "0")}</span
        >
      </div>
      <div class="journey-list">
        {
          items.map((item, index) => (
            <button
              type="button"
              class:list={[
                "journey-card",
                { active: item.slug === initialItem?.slug },
              ]}
              data-map-item={item.slug}
              data-map-kind={item.kind}
              disabled={!item.coordinates && !item.gpx}
              aria-pressed={item.slug === initialItem?.slug}
            >
              <span class="journey-card__index">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span class="journey-card__content">
                <strong class="journey-card__title">{item.title}</strong>
                <span class="journey-card__meta">
                  {item.location}
                  <span aria-hidden="true"> · </span>
                  {item.dateLabel}
                </span>
              </span>
              <span
                class="journey-card__status"
                aria-hidden="true"
                style={`--marker-accent: ${item.accent}`}
              />
            </button>
          ))
        }
      </div>
    </aside>

    <!-- Right: Journey detail panel -->
    <section class="journey-detail" aria-live="polite">
      <header class="journey-detail__header">
        <div class="journey-detail__text">
          <div class="journey-detail__meta">
            <span class="journey-detail__kind" data-map-detail-kind>
              {initialItem?.kindLabel.toUpperCase() ?? ""}
            </span>
            <time
              class="journey-detail__date"
              data-map-detail-date
              datetime={initialItem?.date}
            >
              {initialItem?.dateLabel ?? ""}
            </time>
          </div>
          <h1 class="journey-detail__title" data-map-detail-title>
            {initialItem?.title ?? ""}
          </h1>
          <p class="journey-detail__summary" data-map-detail-description>
            {initialItem?.description ?? ""}
          </p>
          <dl class="journey-detail__stats">
            <div data-map-detail-distance-row hidden={!initialItem?.distance}>
              <dt>{labels.distance}</dt>
              <dd data-map-detail-distance>{initialItem?.distance ?? ""}</dd>
            </div>
            <div data-map-detail-duration-row hidden={!initialItem?.duration}>
              <dt>{labels.duration}</dt>
              <dd data-map-detail-duration>{initialItem?.duration ?? ""}</dd>
            </div>
          </dl>
        </div>
        <a
          class="journey-detail__link"
          href={initialItem?.url ?? `/${locale}/map/`}
          data-map-detail-link
        >
          {labels.details}<span aria-hidden="true">↗</span>
        </a>
      </header>
      <div class="journey-detail__map">
        <div class="journey-map-shell">
          <div
            class="journey-map-canvas"
            aria-label={labels.explore}
          >
          </div>
          <div
            class="journey-map-empty"
            data-map-empty-msg
            hidden={Boolean(
              initialItem?.gpx || initialItem?.route.length,
            )}
          >
            {
              locale === "zh-CN"
                ? "该旅程暂时没有可用的路线数据。"
                : "Route data is not available for this journey."
            }
          </div>
          <div class="journey-map-empty" data-map-fallback-msg hidden>
            {locale === "zh-CN" ? "地图暂时无法加载，路线文字和详情链接仍可使用。" : "The map is unavailable. Route text and detail links remain available."}
          </div>
        </div>
      </div>
    </section>
  </div>

  {mappedCount === 0 && <div class="journey-empty-state">{labels.empty}</div>}
</section>

<script>
  import maplibregl, {
    LngLatBounds,
    type Map as MapLibreMap,
    type Marker,
  } from "maplibre-gl";
  import { parseRouteDocument } from "../lib/routes/gpx";
  import { downsampleSegments } from "../lib/routes/downsample";

  type Point = { lat: number; lng: number };
  type Journey = {
    slug: string;
    title: string;
    description?: string;
    date: string;
    dateLabel: string;
    kind: string;
    kindLabel: string;
    location: string;
    distance?: string;
    duration?: string;
    coordinates?: Point;
    route: Point[];
    gpx?: string;
    accent: string;
    url: string;
    mapZoom?: number;
  };

  const root = document.querySelector<HTMLElement>("[data-map-explorer]");
  if (!root) throw new Error("MapExplorer root not found");

  const items: Journey[] = JSON.parse(root.dataset.items ?? "[]");
  const initialSlug = root.dataset.initialSlug ?? "";
  const isDark = document.documentElement.classList.contains("dark");
  const lightStyle =
    "https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json";
  const darkStyle =
    "https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json";

  // ── State ──
  let map: MapLibreMap | null = null;
  let selectedSlug: string | null = null;
  let currentRouteSourceId: string | null = null;
  let disconnectThemeObserver = () => {};
  const markers = new Map<string, Marker>();
  const routeCache = new Map<string, Point[]>();

  // ── Parse route files through the shared Route System v2 parser ──
  function parseRoutePoints(text: string, gpx: string): Point[] {
    const parsed = parseRouteDocument(text, gpx);
    return downsampleSegments(parsed.segments, 2_000).flat().map(({ lat, lng }) => ({
      lat,
      lng,
    }));
  }

  // ── Fetch & cache route ──
  async function ensureRouteLoaded(item: Journey): Promise<Point[]> {
    if (item.route.length > 1) return item.route;
    if (routeCache.has(item.slug)) return routeCache.get(item.slug)!;
    if (!item.gpx) return [];
    try {
      const resp = await fetch(item.gpx);
      if (!resp.ok) return [];
      const text = await resp.text();
      const points = parseRoutePoints(text, item.gpx);
      if (points.length > 1) {
        item.route = points;
        item.coordinates ??= points[Math.floor(points.length / 2)];
      }
      routeCache.set(item.slug, points);
      return points;
    } catch (e) {
      console.warn(`Route load failed: ${item.gpx}`, e);
      return [];
    }
  }

  // ── Map layer helpers ──
  function removeCurrentRoute() {
    if (!map) return;
    if (currentRouteSourceId && map.getSource(currentRouteSourceId)) {
      try {
        if (map.getLayer("route-glow")) map.removeLayer("route-glow");
      } catch (_) {}
      try {
        if (map.getLayer("route-line")) map.removeLayer("route-line");
      } catch (_) {}
      map.removeSource(currentRouteSourceId);
    }
    currentRouteSourceId = null;
  }

  function addRouteToMap(item: Journey) {
    if (!map || item.route.length < 2) return;
    removeCurrentRoute();
    const sourceId = `route-${item.slug}`;
    currentRouteSourceId = sourceId;
    if (map.getSource(sourceId)) return;
    map.addSource(sourceId, {
      type: "geojson",
      data: {
        type: "Feature",
        properties: {},
        geometry: {
          type: "LineString",
          coordinates: item.route.map((p) => [p.lng, p.lat]),
        },
      },
    });
    map.addLayer({
      id: "route-glow",
      type: "line",
      source: sourceId,
      paint: {
        "line-color": item.accent,
        "line-width": 10,
        "line-opacity": 0.13,
        "line-blur": 5,
      },
    });
    map.addLayer({
      id: "route-line",
      type: "line",
      source: sourceId,
      paint: {
        "line-color": item.accent,
        "line-width": 3.5,
        "line-opacity": 0.9,
      },
    });
  }

  function fitRouteToMap(item: Journey, animate = true) {
    if (!map) return;
    if (item.route.length > 1) {
      const bounds = new LngLatBounds();
      item.route.forEach((p) => bounds.extend([p.lng, p.lat]));
      map.fitBounds(bounds, {
        padding: 40,
        maxZoom: 15,
        duration: animate ? 800 : 0,
      });
    } else if (item.coordinates) {
      map.flyTo({
        center: [item.coordinates.lng, item.coordinates.lat],
        zoom: item.mapZoom ?? 13,
        duration: animate ? 800 : 0,
      });
    }
  }

  // ── Update right-panel UI ──
  function updateDetailUI(item: Journey) {
    const sel = (s: string) => root!.querySelector<HTMLElement>(s)!;
    sel("[data-map-detail-kind]").textContent = item.kindLabel.toUpperCase();
    const dateEl = sel("[data-map-detail-date]") as HTMLTimeElement;
    dateEl.textContent = item.dateLabel;
    dateEl.setAttribute("datetime", item.date);
    sel("[data-map-detail-title]").textContent = item.title;
    sel("[data-map-detail-description]").textContent = item.description ?? "";
    const distRow = sel("[data-map-detail-distance-row]");
    const durRow = sel("[data-map-detail-duration-row]");
    distRow.hidden = !item.distance;
    durRow.hidden = !item.duration;
    sel("[data-map-detail-distance]").textContent = item.distance ?? "";
    sel("[data-map-detail-duration]").textContent = item.duration ?? "";
    (sel("[data-map-detail-link]") as HTMLAnchorElement).href = item.url;
    sel("[data-map-empty-msg]").hidden =
      item.route.length > 1 || !!item.gpx;

    root!
      .querySelectorAll<HTMLButtonElement>("[data-map-item]")
      .forEach((btn) => {
        const isActive = btn.dataset.mapItem === item.slug;
        btn.classList.toggle("active", isActive);
        btn.setAttribute("aria-pressed", String(isActive));
      });
  }

  async function showJourney(item: Journey) {
    selectedSlug = item.slug;
    updateDetailUI(item);

    const url = new URL(window.location.href);
    url.searchParams.set("journey", item.slug);
    window.history.replaceState({ journey: item.slug }, "", url);

    if (item.route.length < 2 && item.gpx) {
      const points = await ensureRouteLoaded(item);
      if (points.length > 1) item.route = points;
      else root!.querySelector<HTMLElement>("[data-map-empty-msg]")!.hidden = false;
    }
    addRouteToMap(item);
    fitRouteToMap(item, true);
  }

  // ── Filter ──
  function applyFilter(kind: string) {
    root!
      .querySelectorAll<HTMLButtonElement>("[data-map-filter]")
      .forEach((btn) => {
        btn.setAttribute("data-active", String(btn.dataset.mapFilter === kind));
      });
    root!
      .querySelectorAll<HTMLButtonElement>("[data-map-item]")
      .forEach((btn) => {
        btn.hidden = kind !== "all" && btn.dataset.mapKind !== kind;
      });
    if (selectedSlug) {
      const sel = items.find((i) => i.slug === selectedSlug);
      if (sel && kind !== "all" && sel.kind !== kind) {
        const first = items.find(
          (i) =>
            (kind === "all" || i.kind === kind) &&
            (i.coordinates || i.gpx),
        );
        if (first) showJourney(first);
      }
    }
    items.forEach((item) => {
      const visible = kind === "all" || item.kind === kind;
      const marker = markers.get(item.slug);
      if (marker) marker.getElement().classList.toggle("filtered", !visible);
      if (!visible && currentRouteSourceId === `route-${item.slug}`)
        removeCurrentRoute();
    });
  }

  const initialJourney =
    items.find((item) => item.slug === initialSlug) ??
    items.find((item) => item.coordinates || item.gpx) ??
    items[0];

  // Render useful route information immediately. The page must remain usable
  // even when the external basemap style is slow or unavailable.
  if (initialJourney) {
    selectedSlug = initialJourney.slug;
    updateDetailUI(initialJourney);
  }

  // ── Init map (once) ──
  try {
    const mapContainer = root.querySelector<HTMLElement>(".journey-map-canvas");
    if (!mapContainer) throw new Error("Map container not found");
    map = new maplibregl.Map({
      container: mapContainer,
      style: isDark ? darkStyle : lightStyle,
      center: [120.15, 30.25],
      zoom: 12,
      minZoom: 1.6,
      maxZoom: 16,
      attributionControl: false,
    });
    map.addControl(
      new maplibregl.NavigationControl({ showCompass: false }),
      "bottom-right",
    );
    map.addControl(
      new maplibregl.AttributionControl({ compact: true }),
      "bottom-right",
    );
  } catch (e) {
    console.warn("MapLibre GL init failed:", e);
    root.classList.add("map-fallback");
    root.querySelector<HTMLElement>("[data-map-fallback-msg]")!.hidden = false;
  }

  if (map) {
    let mapLoaded = false;
    const mapLoadTimeout = window.setTimeout(() => {
      if (!mapLoaded) {
        root.classList.add("map-fallback");
        root.querySelector<HTMLElement>("[data-map-fallback-msg]")!.hidden = false;
        console.warn(
          "Map basemap load timed out; route details remain available.",
        );
      }
    }, 10_000);

    map.on("load", async () => {
      mapLoaded = true;
      window.clearTimeout(mapLoadTimeout);
      root.classList.remove("map-fallback");
      root.querySelector<HTMLElement>("[data-map-fallback-msg]")!.hidden = true;
      items
        .filter((i) => i.coordinates)
        .forEach((item) => {
          const coords = item.coordinates!;
          const el = document.createElement("button");
          el.type = "button";
          el.className = "journey-marker";
          el.dataset.kind = item.kind;
          el.setAttribute("aria-label", item.title);
          el.style.setProperty("--marker-accent", item.accent);
          el.innerHTML = "<span></span>";
          el.addEventListener("click", () => showJourney(item));
          markers.set(
            item.slug,
            new maplibregl.Marker({ element: el })
              .setLngLat([coords.lng, coords.lat])
              .addTo(map!),
          );
        });

      if (initialJourney) await showJourney(initialJourney);
    });

    map.on("error", () => {
      if (!mapLoaded) {
        root.classList.add("map-fallback");
        root.querySelector<HTMLElement>("[data-map-fallback-msg]")!.hidden = false;
      }
    });

    const themeObs = new MutationObserver(() => {
      const nextDark = document.documentElement.classList.contains("dark");
      map!.setStyle(nextDark ? darkStyle : lightStyle);
      map!.once("styledata", () => {
        const sel = items.find((i) => i.slug === selectedSlug);
        if (sel) addRouteToMap(sel);
      });
    });
    themeObs.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
    disconnectThemeObserver = () => themeObs.disconnect();
  }

  // ── Event binding ──
  root.querySelectorAll<HTMLButtonElement>("[data-map-item]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const item = items.find((i) => i.slug === btn.dataset.mapItem);
      if (item && (item.coordinates || item.gpx)) showJourney(item);
    });
  });

  root
    .querySelectorAll<HTMLButtonElement>("[data-map-filter]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        applyFilter(btn.dataset.mapFilter ?? "all");
      });
    });

  const handlePopState = () => {
    const params = new URLSearchParams(window.location.search);
    const slug = params.get("journey");
    const item = slug ? items.find((i) => i.slug === slug) : null;
    if (item && (item.coordinates || item.gpx)) showJourney(item);
  };
  window.addEventListener("popstate", handlePopState);

  const resizeMap = () => map?.resize();
  window.addEventListener("resize", resizeMap, { passive: true });
  window.addEventListener("orientationchange", resizeMap, { passive: true });
  document.addEventListener(
    "astro:before-swap",
    () => {
      window.removeEventListener("resize", resizeMap);
      window.removeEventListener("orientationchange", resizeMap);
      window.removeEventListener("popstate", handlePopState);
      disconnectThemeObserver();
      markers.forEach((marker) => marker.remove());
      map?.remove();
      map = null;
    },
    { once: true },
  );
</script>

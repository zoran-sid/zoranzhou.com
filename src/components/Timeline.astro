---
import { TIMELINE } from "../lib/constants";
---

<section class="surface-about py-24 md:py-32">
  <div class="page-container">
    <div class="mb-14">
      <span class="text-sm font-semibold uppercase tracking-widest text-blue-600 dark:text-blue-400">
        Journey
      </span>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 dark:text-gray-100">
        Timeline
      </h2>
    </div>

    <div class="relative max-w-2xl">
      {/* vertical line */}
      <div
        class="absolute left-[11px] top-2 bottom-2 w-px bg-gray-200 dark:bg-gray-800"
        aria-hidden="true"
      ></div>

      <div class="space-y-10">
        {TIMELINE.map((item, i) => (
          <div class="relative pl-10">
            {/* dot */}
            <div
              class={`absolute left-0 top-1.5 h-[22px] w-[22px] rounded-full border-2 bg-white dark:bg-gray-900 ${
                i === 0
                  ? "border-blue-500 bg-blue-50 dark:border-blue-400 dark:bg-blue-900/30"
                  : "border-gray-300 dark:border-gray-700"
              }`}
              aria-hidden="true"
            ></div>

            <span class="text-sm font-semibold text-blue-600 dark:text-blue-400">{item.year}</span>
            <h3 class="mt-1 text-lg font-semibold text-gray-900 dark:text-gray-100">{item.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
